<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="100" d:DesignHeight="400"
             x:Class="VisualGameStudio.Editor.Controls.MinimapControl"
             Width="100"
             ClipToBounds="True">

  <Panel>
    <!-- Custom-rendered code overview (drawn in OnRender) -->
    <Border x:Name="RenderSurface"
            Background="#191919"
            ClipToBounds="True"/>
    <!-- Viewport indicator and hover highlight are drawn in Render() to avoid layout invalidation -->
  </Panel>

</UserControl>
