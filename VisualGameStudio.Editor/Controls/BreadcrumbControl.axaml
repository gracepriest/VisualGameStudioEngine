<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="24"
             x:Class="VisualGameStudio.Editor.Controls.BreadcrumbControl"
             Background="#252526"
             Height="24">

  <ItemsControl x:Name="BreadcrumbItems"
                VerticalAlignment="Center">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <StackPanel Orientation="Horizontal" Margin="6,0"/>
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Icon badge for the segment kind -->
          <Border Background="{Binding IconBackground}"
                  CornerRadius="2"
                  Padding="2,0"
                  Margin="0,0,2,0"
                  VerticalAlignment="Center"
                  IsVisible="{Binding HasIcon}">
            <TextBlock Text="{Binding Icon}"
                       FontSize="9"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
          </Border>

          <!-- Clickable segment name (left-click navigates, right-click or chevron opens dropdown) -->
          <Button x:Name="SegmentButton"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="3,2"
                  FontSize="12"
                  Foreground="{Binding SegmentForeground}"
                  Cursor="Hand"
                  Tag="{Binding}"
                  Click="OnSegmentClicked">
            <Button.Styles>
              <Style Selector="Button:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#37373D"/>
              </Style>
            </Button.Styles>
            <StackPanel Orientation="Horizontal" Spacing="2">
              <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
              <!-- Small dropdown chevron when siblings are available -->
              <TextBlock Text="&#x25BE;"
                         FontSize="8"
                         Foreground="#808080"
                         VerticalAlignment="Center"
                         Margin="1,1,0,0"
                         IsVisible="{Binding HasSiblings}"/>
            </StackPanel>
          </Button>

          <!-- Chevron separator -->
          <TextBlock Text="&#xE76C;"
                     FontFamily="Segoe MDL2 Assets"
                     VerticalAlignment="Center"
                     Foreground="#6E6E6E"
                     Margin="2,0"
                     FontSize="8"
                     IsVisible="{Binding ShowSeparator}"/>
        </StackPanel>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
