<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:VisualGameStudio.Shell"
        xmlns:idc="using:Dock.Avalonia.Controls"
        xmlns:ds="using:Dock.Settings"
        xmlns:psp="using:Dock.Controls.ProportionalStackPanel">

  <!-- ========== DARK THEME ========== -->
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="IdeBg" Color="#1E1E1E"/>
          <SolidColorBrush x:Key="IdeFg" Color="#CCCCCC"/>
          <SolidColorBrush x:Key="IdePanelBg" Color="#252526"/>
          <SolidColorBrush x:Key="IdeMenuBg" Color="#2D2D2D"/>
          <SolidColorBrush x:Key="IdeBorder" Color="#3C3C3C"/>
          <SolidColorBrush x:Key="IdeHoverBg" Color="#3E3E3E"/>
          <SolidColorBrush x:Key="IdeInputBg" Color="#3C3C3C"/>
          <SolidColorBrush x:Key="IdeInputBorder" Color="#5A5A5A"/>
          <SolidColorBrush x:Key="IdeSelectionBg" Color="#264F78"/>
          <SolidColorBrush x:Key="IdeHeaderBg" Color="#3C3C3C"/>
          <SolidColorBrush x:Key="IdeThumbBg" Color="#424242"/>
          <SolidColorBrush x:Key="IdeThumbHover" Color="#5A5A5A"/>
          <SolidColorBrush x:Key="IdeContextBg" Color="#252526"/>
          <SolidColorBrush x:Key="IdeContextBorder" Color="#454545"/>
          <SolidColorBrush x:Key="IdeSecondaryBg" Color="#3C3C3C"/>
          <SolidColorBrush x:Key="IdeSecondaryFg" Color="#CCCCCC"/>
          <SolidColorBrush x:Key="IdeSecondaryBorder" Color="#5A5A5A"/>
          <SolidColorBrush x:Key="IdeSecondaryHover" Color="#4A4A4A"/>
          <SolidColorBrush x:Key="IdeListHover" Color="#2A2D2E"/>
          <SolidColorBrush x:Key="IdeListSelected" Color="#094771"/>
          <SolidColorBrush x:Key="IdeFooterBg" Color="#2D2D2D"/>
          <SolidColorBrush x:Key="IdeFooterBorder" Color="#3C3C3C"/>
          <SolidColorBrush x:Key="IdeStatusBarBg" Color="#007ACC"/>
          <SolidColorBrush x:Key="IdeStatusBarDebugBg" Color="#CC6800"/>
          <!-- Task 1.6 surface keys: editor canvas, accent, muted/subtle text, popup overlay,
               activity bar, and semantic (warning/success/error/diff) surfaces. -->
          <SolidColorBrush x:Key="IdeEditorBg" Color="#1E1E1E"/>
          <SolidColorBrush x:Key="IdeAccent" Color="#3794FF"/>
          <SolidColorBrush x:Key="IdeFgMuted" Color="#808080"/>
          <SolidColorBrush x:Key="IdeFgSubtle" Color="#606060"/>
          <SolidColorBrush x:Key="IdeOverlayBg" Color="#E8252526"/>
          <SolidColorBrush x:Key="IdeActivityBarBg" Color="#333333"/>
          <SolidColorBrush x:Key="IdeActivityBarFg" Color="#CCCCCC"/>
          <SolidColorBrush x:Key="IdeWarningBg" Color="#3D2C1E"/>
          <SolidColorBrush x:Key="IdeWarningBorder" Color="#A67C52"/>
          <SolidColorBrush x:Key="IdeWarningFg" Color="#CCA700"/>
          <SolidColorBrush x:Key="IdeSuccessBg" Color="#2D4F3E"/>
          <SolidColorBrush x:Key="IdeSuccessBorder" Color="#3E6B51"/>
          <SolidColorBrush x:Key="IdeSuccessFg" Color="#4EC9B0"/>
          <SolidColorBrush x:Key="IdeErrorBg" Color="#3D1E1E"/>
          <SolidColorBrush x:Key="IdeErrorBorder" Color="#A65252"/>
          <SolidColorBrush x:Key="IdeErrorFg" Color="#F48771"/>
          <SolidColorBrush x:Key="IdeDiffAddedBg" Color="#1E3A1E"/>
          <SolidColorBrush x:Key="IdeDiffRemovedBg" Color="#3A1E1E"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="IdeBg" Color="#F5F5F5"/>
          <SolidColorBrush x:Key="IdeFg" Color="#1E1E1E"/>
          <SolidColorBrush x:Key="IdePanelBg" Color="#EEEEF2"/>
          <SolidColorBrush x:Key="IdeMenuBg" Color="#E8E8E8"/>
          <SolidColorBrush x:Key="IdeBorder" Color="#CCCEDB"/>
          <SolidColorBrush x:Key="IdeHoverBg" Color="#D8D8DC"/>
          <SolidColorBrush x:Key="IdeInputBg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeInputBorder" Color="#CCCEDB"/>
          <SolidColorBrush x:Key="IdeSelectionBg" Color="#ADD6FF"/>
          <SolidColorBrush x:Key="IdeHeaderBg" Color="#DDDDE1"/>
          <SolidColorBrush x:Key="IdeThumbBg" Color="#C2C2C2"/>
          <SolidColorBrush x:Key="IdeThumbHover" Color="#999999"/>
          <SolidColorBrush x:Key="IdeContextBg" Color="#F6F6F6"/>
          <SolidColorBrush x:Key="IdeContextBorder" Color="#C8C8C8"/>
          <SolidColorBrush x:Key="IdeSecondaryBg" Color="#E5E5E5"/>
          <SolidColorBrush x:Key="IdeSecondaryFg" Color="#1E1E1E"/>
          <SolidColorBrush x:Key="IdeSecondaryBorder" Color="#C8C8C8"/>
          <SolidColorBrush x:Key="IdeSecondaryHover" Color="#D0D0D0"/>
          <SolidColorBrush x:Key="IdeListHover" Color="#E0E0E4"/>
          <SolidColorBrush x:Key="IdeListSelected" Color="#CCE8FF"/>
          <SolidColorBrush x:Key="IdeFooterBg" Color="#E8E8E8"/>
          <SolidColorBrush x:Key="IdeFooterBorder" Color="#CCCEDB"/>
          <SolidColorBrush x:Key="IdeStatusBarBg" Color="#007ACC"/>
          <SolidColorBrush x:Key="IdeStatusBarDebugBg" Color="#CC6800"/>
          <!-- Task 1.6 surface keys (light equivalents: white canvas, darker accent,
               readable muted/subtle text, pale semantic surfaces with dark text). -->
          <SolidColorBrush x:Key="IdeEditorBg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeAccent" Color="#0066BF"/>
          <SolidColorBrush x:Key="IdeFgMuted" Color="#616161"/>
          <SolidColorBrush x:Key="IdeFgSubtle" Color="#8E8E8E"/>
          <SolidColorBrush x:Key="IdeOverlayBg" Color="#E8F6F6F6"/>
          <SolidColorBrush x:Key="IdeActivityBarBg" Color="#2C2C2C"/>
          <SolidColorBrush x:Key="IdeActivityBarFg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeWarningBg" Color="#FFF8E1"/>
          <SolidColorBrush x:Key="IdeWarningBorder" Color="#E6C200"/>
          <SolidColorBrush x:Key="IdeWarningFg" Color="#7A5D00"/>
          <SolidColorBrush x:Key="IdeSuccessBg" Color="#E6F4EA"/>
          <SolidColorBrush x:Key="IdeSuccessBorder" Color="#4CAF50"/>
          <SolidColorBrush x:Key="IdeSuccessFg" Color="#107C41"/>
          <SolidColorBrush x:Key="IdeErrorBg" Color="#FDE7E9"/>
          <SolidColorBrush x:Key="IdeErrorBorder" Color="#E06C75"/>
          <SolidColorBrush x:Key="IdeErrorFg" Color="#A1260D"/>
          <SolidColorBrush x:Key="IdeDiffAddedBg" Color="#E6FFED"/>
          <SolidColorBrush x:Key="IdeDiffRemovedBg" Color="#FFEEF0"/>
        </ResourceDictionary>
        <!-- High Contrast: a real ThemeVariant (AppThemes.HighContrast inherits Dark), so any
             Ide* key NOT overridden here falls back to the Dark dictionary above. These 22 keys
             were formerly in a dead <Style Selector="Window.highContrast"><Style.Resources> block
             (Style.Resources are not selector-scoped, so theme-dictionary lookup won first and HC
             silently rendered with the Dark palette). -->
        <ResourceDictionary x:Key="{x:Static local:AppThemes.HighContrast}">
          <SolidColorBrush x:Key="IdeBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeFg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdePanelBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeMenuBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeBorder" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeHoverBg" Color="#1A1A2E"/>
          <SolidColorBrush x:Key="IdeInputBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeInputBorder" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeSelectionBg" Color="#264F78"/>
          <SolidColorBrush x:Key="IdeHeaderBg" Color="#1A1A1A"/>
          <SolidColorBrush x:Key="IdeThumbBg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeThumbHover" Color="#FFFF00"/>
          <SolidColorBrush x:Key="IdeContextBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeContextBorder" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeSecondaryBg" Color="#1A1A1A"/>
          <SolidColorBrush x:Key="IdeSecondaryFg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeSecondaryBorder" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeSecondaryHover" Color="#1A1A2E"/>
          <SolidColorBrush x:Key="IdeListHover" Color="#1A1A2E"/>
          <SolidColorBrush x:Key="IdeListSelected" Color="#264F78"/>
          <SolidColorBrush x:Key="IdeFooterBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeFooterBorder" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeStatusBarBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeStatusBarDebugBg" Color="#000000"/>
          <!-- Task 1.6 surface keys (High Contrast: black surfaces; yellow for warning/accent,
               white for success/error borders + text — HC conveys state via glyphs + borders,
               not hue). Keys absent here fall back to the Dark dictionary via the variant parent. -->
          <SolidColorBrush x:Key="IdeEditorBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeAccent" Color="#FFFF00"/>
          <SolidColorBrush x:Key="IdeFgMuted" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeFgSubtle" Color="#C0C0C0"/>
          <SolidColorBrush x:Key="IdeOverlayBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeActivityBarBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeActivityBarFg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeWarningBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeWarningBorder" Color="#FFFF00"/>
          <SolidColorBrush x:Key="IdeWarningFg" Color="#FFFF00"/>
          <SolidColorBrush x:Key="IdeSuccessBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeSuccessBorder" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeSuccessFg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeErrorBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeErrorBorder" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeErrorFg" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="IdeDiffAddedBg" Color="#000000"/>
          <SolidColorBrush x:Key="IdeDiffRemovedBg" Color="#000000"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Base styles below. The "Window.highContrast ..." OVERRIDES live at the END of this file:
       Avalonia has no CSS specificity — declaration order is the only tiebreaker (last-declared
       setter wins for a given property), so the HC overrides MUST come after every base class
       style or the base styles silently kill them. See the banner at the bottom. -->

  <!-- Window -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource IdeBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
  </Style>

  <!-- Menu -->
  <Style Selector="Menu">
    <Setter Property="Background" Value="{DynamicResource IdeMenuBg}"/>
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource IdeHoverBg}"/>
  </Style>

  <!-- TreeView styling -->
  <Style Selector="TreeView">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
  </Style>

  <Style Selector="TreeViewItem">
    <Setter Property="Padding" Value="2"/>
  </Style>

  <!-- Tab styling for documents -->
  <Style Selector="TabControl">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
  </Style>

  <!-- Status bar. Background is theme-aware via DynamicResource (was a hardcoded
       #007ACC + a local converter binding in MainWindow.axaml that beat every style,
       including the HC black override). The debug-session orange is now a style-class
       swap: code-behind toggles the "statusBarDebug" class on IsDebugging, and the
       DynamicResource re-resolves for free on a theme-variant switch. -->
  <Style Selector="Border.statusBar">
    <Setter Property="Background" Value="{DynamicResource IdeStatusBarBg}"/>
    <Setter Property="Height" Value="22"/>
  </Style>
  <Style Selector="Border.statusBar.statusBarDebug">
    <Setter Property="Background" Value="{DynamicResource IdeStatusBarDebugBg}"/>
  </Style>

  <!-- Status bar buttons: transparent chrome on the accent bar so they don't render as
       raw Fluent boxes ("white lines"). Mirrors StatusBarControl's Button.statusItem.
       The HC section at file end gives these a white 1px border on top of this. -->
  <Style Selector="Button.statusBarButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="0"/>
    <Setter Property="Padding" Value="6,2"/>
  </Style>
  <Style Selector="Button.statusBarButton:pointerover">
    <Setter Property="Background" Value="#FFFFFF20"/>
  </Style>
  <Style Selector="Button.statusBarButton:pressed">
    <Setter Property="Background" Value="#FFFFFF30"/>
  </Style>

  <!-- Skip-navigation links: a real accent affordance for keyboard focus (was HC-only,
       so it rendered as raw Fluent chrome in Dark/Light). HC override at file end wins. -->
  <Style Selector="Button.skipNavLink">
    <Setter Property="Background" Value="#007ACC"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <!-- Tool panels -->
  <Style Selector="Border.toolPanel">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource IdeBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- Panel headers -->
  <Style Selector="Border.panelHeader">
    <Setter Property="Background" Value="{DynamicResource IdeHeaderBg}"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <Style Selector="TextBlock.panelTitle">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
  </Style>

  <!-- DataGrid styling -->
  <Style Selector="DataGrid">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
    <Setter Property="RowBackground" Value="{DynamicResource IdePanelBg}"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="HeadersVisibility" Value="Column"/>
  </Style>

  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource IdeHeaderBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <!-- Buttons -->
  <Style Selector="Button.toolbarButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="4"/>
    <Setter Property="MinWidth" Value="24"/>
    <Setter Property="MinHeight" Value="24"/>
  </Style>

  <Style Selector="Button.toolbarButton:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource IdeHoverBg}"/>
  </Style>

  <!-- Pressed state was previously unstyled, so clicking a toolbarButton fell through to
       raw Fluent chrome (a light/white box even on a dark bar, or vice-versa in Light) —
       the same "white lines" bug class as the unstyled hover state. One step stronger than
       :pointerover's IdeHoverBg so press gives visible feedback over hover. -->
  <Style Selector="Button.toolbarButton:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource IdeSecondaryHover}"/>
  </Style>

  <!-- Dock.Avalonia Tool Tab Styling -->
  <Style Selector="idc|ToolControl">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
  </Style>

  <!-- Style the tool tab strip for better visibility -->
  <Style Selector="idc|ToolTabStrip">
    <Setter Property="Background" Value="{DynamicResource IdeMenuBg}"/>
    <!-- Make the tab bar a dock target so dropping a dragged tab onto it docks the panel there
         (the natural gesture), not just the panel body. Bigger, more forgiving drop surface. -->
    <Setter Property="(ds:DockProperties.IsDockTarget)" Value="True"/>
  </Style>

  <Style Selector="idc|DocumentTabStrip">
    <Setter Property="(ds:DockProperties.IsDockTarget)" Value="True"/>
  </Style>

  <Style Selector="idc|ToolTabStripItem">
    <Setter Property="Background" Value="{DynamicResource IdeMenuBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <Style Selector="idc|ToolTabStripItem:selected">
    <Setter Property="Background" Value="{DynamicResource IdeHeaderBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
  </Style>

  <Style Selector="idc|ToolTabStripItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource IdeHoverBg}"/>
  </Style>

  <!-- Tool chrome styling -->
  <Style Selector="idc|ToolChromeControl">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
  </Style>

  <!-- Let panels be dragged much smaller: Dock's splitter defaults to a 75px minimum,
       which stops panels from shrinking. Lower it so they can be made narrow/short.
       (Dock 11.3 moved the splitter into the Dock.Controls.ProportionalStackPanel package.) -->
  <Style Selector="psp|ProportionalStackPanelSplitter">
    <Setter Property="(psp:ProportionalStackPanelSplitter.MinimumProportionSize)" Value="24"/>
  </Style>

  <!-- Primary button styling -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#0E639C"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="#1177BB"/>
  </Style>

  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="#0D5687"/>
  </Style>

  <!-- Secondary button styling -->
  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource IdeSecondaryBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeSecondaryFg}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource IdeSecondaryBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <Style Selector="Button.secondary:pointerover">
    <Setter Property="Background" Value="{DynamicResource IdeSecondaryHover}"/>
  </Style>

  <!-- TextBox styling -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource IdeInputBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource IdeInputBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource IdeSelectionBg}"/>
    <Setter Property="CaretBrush" Value="{DynamicResource IdeFg}"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="#007ACC"/>
  </Style>

  <Style Selector="TextBox:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource IdeThumbHover}"/>
  </Style>

  <!-- ComboBox styling -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource IdeInputBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource IdeInputBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="#007ACC"/>
  </Style>

  <!-- ListBox styling -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource IdeBorder}"/>
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource IdeListSelected}"/>
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource IdeListHover}"/>
  </Style>

  <!-- Context Menu styling -->
  <Style Selector="ContextMenu">
    <Setter Property="Background" Value="{DynamicResource IdeContextBg}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource IdeContextBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <Style Selector="ContextMenu MenuItem">
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <Style Selector="ContextMenu Separator">
    <Setter Property="Background" Value="{DynamicResource IdeContextBorder}"/>
    <Setter Property="Height" Value="1"/>
    <Setter Property="Margin" Value="8,4"/>
  </Style>

  <!-- ScrollBar styling -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource IdeThumbBg}"/>
    <Setter Property="CornerRadius" Value="4"/>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource IdeThumbHover}"/>
  </Style>

  <!-- CheckBox styling -->
  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
  </Style>

  <!-- Tooltip styling -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{DynamicResource IdeMenuBg}"/>
    <Setter Property="Foreground" Value="{DynamicResource IdeFg}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource IdeContextBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <!-- Expander styling -->
  <Style Selector="Expander">
    <Setter Property="Background" Value="{DynamicResource IdePanelBg}"/>
  </Style>

  <Style Selector="Expander /template/ ToggleButton">
    <Setter Property="Background" Value="{DynamicResource IdeHeaderBg}"/>
  </Style>

  <!-- Progress bar styling -->
  <Style Selector="ProgressBar">
    <Setter Property="Background" Value="{DynamicResource IdeHeaderBg}"/>
    <Setter Property="Foreground" Value="#0E639C"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <!-- Activity bar button -->
  <Style Selector="Button.activityBarButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width" Value="48"/>
    <Setter Property="Height" Value="48"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Foreground" Value="#808080"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="CornerRadius" Value="0"/>
  </Style>

  <Style Selector="Button.activityBarButton:pointerover">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>

  <Style Selector="Button.activityBarButton:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <!-- Splitter styling -->
  <Style Selector="GridSplitter">
    <Setter Property="Background" Value="{DynamicResource IdeBorder}"/>
  </Style>

  <Style Selector="GridSplitter:pointerover">
    <Setter Property="Background" Value="#007ACC"/>
  </Style>

  <!-- ============================================================================ -->
  <!-- ========== HIGH CONTRAST THEME OVERRIDES — MUST STAY LAST ================== -->
  <!-- ============================================================================ -->
  <!-- Avalonia has NO CSS-style specificity: when two matching styles set the same
       property, the LAST-DECLARED one wins. These "Window.highContrast ..." class
       overrides therefore have to sit after EVERY base class style above — otherwise
       base styles like Button.toolbarButton / Button.primary / Border.statusBar /
       Menu / TreeView / TextBox / ComboBox (declared earlier) would silently kill
       them. (They previously sat between Styles.Resources and the base styles, so all
       of the above were dead.) Keep this whole block at the very end of the file.

       These styles activate when ThemeManager adds the "highContrast" class to the
       window. The HC brush palette itself lives in the AppThemes.HighContrast
       ThemeDictionary above; the window's black background / white foreground come
       from the base Window style resolving IdeBg/IdeFg against the HighContrast
       variant. -->

  <!-- High Contrast: Menu -->
  <Style Selector="Window.highContrast Menu">
    <Setter Property="Background" Value="#000000"/>
  </Style>
  <Style Selector="Window.highContrast MenuItem">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast MenuItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#1A1A2E"/>
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- High Contrast: TreeView -->
  <Style Selector="Window.highContrast TreeView">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast TreeViewItem">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>

  <!-- High Contrast: TabControl -->
  <Style Selector="Window.highContrast TabControl">
    <Setter Property="Background" Value="#000000"/>
  </Style>
  <Style Selector="Window.highContrast TabItem">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast TabItem:selected">
    <Setter Property="Foreground" Value="#FFFF00"/>
  </Style>

  <!-- High Contrast: Status bar -->
  <Style Selector="Window.highContrast Border.statusBar">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1,1,1,0"/>
  </Style>

  <!-- High Contrast: Buttons -->
  <Style Selector="Window.highContrast Button">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style Selector="Window.highContrast Button:pointerover">
    <Setter Property="Background" Value="#1A1A2E"/>
    <Setter Property="BorderBrush" Value="#FFFF00"/>
  </Style>
  <Style Selector="Window.highContrast Button:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>
  <Style Selector="Window.highContrast Button.primary">
    <Setter Property="Background" Value="#000080"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style Selector="Window.highContrast Button.primary:pointerover">
    <Setter Property="Background" Value="#0000CC"/>
    <Setter Property="BorderBrush" Value="#FFFF00"/>
  </Style>

  <!-- High Contrast: TextBox with visible focus ring -->
  <Style Selector="Window.highContrast TextBox">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CaretBrush" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast TextBox:focus">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <!-- High Contrast: ComboBox -->
  <Style Selector="Window.highContrast ComboBox">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style Selector="Window.highContrast ComboBox:focus">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <!-- High Contrast: ListBox -->
  <Style Selector="Window.highContrast ListBox">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast ListBoxItem">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast ListBoxItem:selected">
    <Setter Property="Background" Value="#264F78"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast ListBoxItem:pointerover">
    <Setter Property="Background" Value="#1A1A2E"/>
  </Style>

  <!-- High Contrast: CheckBox -->
  <Style Selector="Window.highContrast CheckBox">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>

  <!-- High Contrast: TextBlock (default text) -->
  <Style Selector="Window.highContrast TextBlock">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>

  <!-- High Contrast: ContextMenu -->
  <Style Selector="Window.highContrast ContextMenu">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- High Contrast: ToolTip -->
  <Style Selector="Window.highContrast ToolTip">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- High Contrast: DataGrid -->
  <Style Selector="Window.highContrast DataGrid">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="RowBackground" Value="#000000"/>
  </Style>
  <Style Selector="Window.highContrast DataGridColumnHeader">
    <Setter Property="Background" Value="#1A1A1A"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
  </Style>

  <!-- High Contrast: GridSplitter -->
  <Style Selector="Window.highContrast GridSplitter">
    <Setter Property="Background" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast GridSplitter:pointerover">
    <Setter Property="Background" Value="#FFFF00"/>
  </Style>

  <!-- High Contrast: ScrollBar -->
  <Style Selector="Window.highContrast ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Background" Value="#FFFF00"/>
  </Style>

  <!-- High Contrast: ProgressBar -->
  <Style Selector="Window.highContrast ProgressBar">
    <Setter Property="Background" Value="#1A1A1A"/>
    <Setter Property="Foreground" Value="#FFFF00"/>
  </Style>

  <!-- High Contrast: Expander -->
  <Style Selector="Window.highContrast Expander">
    <Setter Property="Background" Value="#000000"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>

  <!-- High Contrast: 3px focus borders on all focusable elements -->
  <Style Selector="Window.highContrast TextBox:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast ComboBox:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast Button:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast ListBoxItem:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast TreeViewItem:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast CheckBox:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast TabItem:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast MenuItem:focus-visible /template/ Border#PART_LayoutRoot">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- High Contrast: Selected states with bold borders (not just color) -->
  <Style Selector="Window.highContrast ListBoxItem:selected">
    <Setter Property="Background" Value="#264F78"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>
  <Style Selector="Window.highContrast TreeViewItem:selected">
    <Setter Property="Background" Value="#264F78"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <!-- High Contrast: DataGridRow selected -->
  <Style Selector="Window.highContrast DataGridRow:selected">
    <Setter Property="Background" Value="#264F78"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast DataGridRow:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- High Contrast: Ensure links and interactive text use underline not just color -->
  <Style Selector="Window.highContrast Button.statusBarButton">
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Window.highContrast Button.statusBarButton:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast Button.statusBarButton:pointerover">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
  </Style>

  <!-- ===== Icon buttons: no stray 1px box (Step 2) =====
       The blanket "Window.highContrast Button" above gives EVERY button a 1px white
       border. On tiny icon buttons that draws an ugly box. One consistent treatment
       for all icon-button surfaces: BorderThickness=0, hover background inherited from
       the blanket Button:pointerover, and a yellow focus-visible ring only. Content
       buttons (Button.primary / secondary / skipNavLink / classless dialog buttons)
       KEEP the white 1px border. Declared AFTER the blanket so they win. Each surface
       needs the focus-visible pair too, or the blanket's 3px ring would be re-killed by
       the BorderThickness=0 base override. -->

  <!-- Panel-header toolbar icon buttons (SolutionExplorer, Terminal, Watch, Git, etc.) -->
  <Style Selector="Window.highContrast Button.toolbarButton">
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Window.highContrast Button.toolbarButton:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- Debug Console toolbar icon buttons (local Button.toolbar-btn class) -->
  <Style Selector="Window.highContrast Button.toolbar-btn">
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Window.highContrast Button.toolbar-btn:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- Dock tool chrome icon buttons (pin / close / menu — Dock's ChromeButton parts) -->
  <Style Selector="Window.highContrast idc|ToolChromeControl Button">
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Window.highContrast idc|ToolChromeControl Button:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- Tab close ('x') buttons on tool + document tab strips -->
  <Style Selector="Window.highContrast idc|ToolTabStrip Button">
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Window.highContrast idc|ToolTabStrip Button:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>
  <Style Selector="Window.highContrast idc|DocumentTabStrip Button">
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Window.highContrast idc|DocumentTabStrip Button:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- High Contrast: Skip navigation links -->
  <Style Selector="Window.highContrast Button.skipNavLink">
    <Setter Property="Background" Value="#000080"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>
  <Style Selector="Window.highContrast Button.skipNavLink:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- High Contrast: Activity bar button (48x48 — keep a visible border; not a tiny icon button) -->
  <Style Selector="Window.highContrast Button.activityBarButton">
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#FFFFFF"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style Selector="Window.highContrast Button.activityBarButton:focus-visible">
    <Setter Property="BorderBrush" Value="#FFFF00"/>
    <Setter Property="BorderThickness" Value="3"/>
  </Style>

  <!-- ========== END HIGH CONTRAST OVERRIDES ========== -->

  <!-- GUARD: do NOT add new base/component styles below this line. The HC block above
       must stay LAST — Avalonia has no specificity, so any style declared after it runs
       later and silently un-overrides the HC theme. New styles go up with the base styles. -->

</Styles>
