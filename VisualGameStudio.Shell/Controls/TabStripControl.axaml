<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VisualGameStudio.Shell.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="35"
             x:Class="VisualGameStudio.Shell.Controls.TabStripControl"
             x:DataType="vm:TabManagerViewModel"
             Background="#252526">

  <UserControl.Styles>
    <!-- Base tab item style -->
    <Style Selector="Border.tabItem">
      <Setter Property="Background" Value="#2D2D2D"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
      <Setter Property="BorderThickness" Value="0,0,1,0"/>
      <Setter Property="Padding" Value="10,4,4,4"/>
      <Setter Property="MinHeight" Value="35"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Active tab -->
    <Style Selector="Border.tabItem.active">
      <Setter Property="Background" Value="#1E1E1E"/>
      <Setter Property="BorderBrush" Value="#1E1E1E"/>
      <Setter Property="BorderThickness" Value="0,2,1,0"/>
    </Style>

    <!-- Hover tab -->
    <Style Selector="Border.tabItem:pointerover">
      <Setter Property="Background" Value="#2A2D2E"/>
    </Style>

    <!-- Active tab top border (accent) -->
    <Style Selector="Border.tabItem.active">
      <Setter Property="BorderBrush" Value="#569CD6"/>
    </Style>

    <!-- Tab close button -->
    <Style Selector="Button.tabCloseBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Width" Value="20"/>
      <Setter Property="Height" Value="20"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Show close button on hover -->
    <Style Selector="Border.tabItem:pointerover Button.tabCloseBtn">
      <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="Button.tabCloseBtn:pointerover">
      <Setter Property="Opacity" Value="1"/>
      <Setter Property="Background" Value="#3C3C3C"/>
    </Style>

    <!-- Modified dot replaces close button when modified and not hovered -->
    <Style Selector="Border.tabItem Ellipse.modifiedDot">
      <Setter Property="IsVisible" Value="True"/>
    </Style>
    <Style Selector="Border.tabItem:pointerover Ellipse.modifiedDot">
      <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Preview tab italic title -->
    <Style Selector="TextBlock.previewTitle">
      <Setter Property="FontStyle" Value="Italic"/>
    </Style>

    <!-- Pinned tab compact style -->
    <Style Selector="Border.tabItem.pinned">
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="MaxWidth" Value="45"/>
    </Style>

    <!-- Error underline -->
    <Style Selector="Border.errorUnderline">
      <Setter Property="BorderBrush" Value="#E51400"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
    </Style>

    <!-- Overflow button -->
    <Style Selector="Button.overflowBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="#CCCCCC"/>
    </Style>
    <Style Selector="Button.overflowBtn:pointerover">
      <Setter Property="Background" Value="#3C3C3C"/>
    </Style>

    <!-- Split button -->
    <Style Selector="Button.splitBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="#808080"/>
    </Style>
    <Style Selector="Button.splitBtn:pointerover">
      <Setter Property="Background" Value="#3C3C3C"/>
      <Setter Property="Foreground" Value="#CCCCCC"/>
    </Style>

    <!-- Drop indicator line -->
    <Style Selector="Border.dropIndicator">
      <Setter Property="Width" Value="2"/>
      <Setter Property="Background" Value="#569CD6"/>
      <Setter Property="IsVisible" Value="False"/>
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="*,Auto,Auto">
    <!-- Scrollable tab area -->
    <ScrollViewer Grid.Column="0"
                  HorizontalScrollBarVisibility="Hidden"
                  VerticalScrollBarVisibility="Disabled"
                  Name="TabScrollViewer">
      <ItemsControl ItemsSource="{Binding Tabs}" Name="TabItemsControl">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="0"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:TabItemViewModel">
            <Border Classes="tabItem"
                    Classes.active="{Binding IsActive}"
                    Classes.pinned="{Binding IsPinned}"
                    PointerPressed="OnTabPointerPressed"
                    PointerReleased="OnTabPointerReleased"
                    PointerMoved="OnTabPointerMoved"
                    Tag="{Binding}"
                    DragDrop.AllowDrop="True"
                    AutomationProperties.Name="{Binding FileName}">
              <Border Classes.errorUnderline="{Binding HasErrors}">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto">
                  <!-- File icon / Pin icon for pinned tabs -->
                  <Panel Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Center">
                    <!-- Pin icon (shown for pinned tabs) -->
                    <TextBlock Text="&#x1F4CC;" FontSize="11"
                               IsVisible="{Binding IsPinned}"
                               ToolTip.Tip="Pinned"/>
                    <!-- File type icon (shown for unpinned tabs) -->
                    <Border CornerRadius="2" Padding="2,0" MinWidth="16"
                            IsVisible="{Binding !IsPinned}"
                            HorizontalAlignment="Center">
                      <TextBlock Text="{Binding IconGlyph}"
                                 Foreground="{Binding IconColor}"
                                 FontSize="10" FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                  </Panel>

                  <!-- Tab title (hidden for pinned tabs) -->
                  <TextBlock Grid.Column="1"
                             Text="{Binding FileName}"
                             Foreground="#CCCCCC"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"
                             FontSize="12"
                             IsVisible="{Binding !IsPinned}"
                             Classes.previewTitle="{Binding IsPreview}"/>

                  <!-- Git status decoration dot -->
                  <Ellipse Grid.Column="2"
                           Width="6" Height="6"
                           Fill="{Binding GitDecorationColor}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           IsVisible="{Binding ShowGitDecoration}"
                           ToolTip.Tip="{Binding GitStatus}"/>

                  <!-- Close button / Modified dot area -->
                  <Panel Grid.Column="3" Width="20" Height="20"
                         VerticalAlignment="Center"
                         IsVisible="{Binding !IsPinned}">
                    <!-- Modified dot (shown when modified and tab not hovered) -->
                    <Ellipse Classes="modifiedDot"
                             Width="8" Height="8"
                             Fill="#CCCCCC"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsModified}"/>

                    <!-- Close button (shown on hover, replaces dot) -->
                    <Button Classes="tabCloseBtn"
                            Click="OnTabCloseClick"
                            Tag="{Binding}"
                            ToolTip.Tip="Close (Ctrl+W)">
                      <TextBlock Text="&#x2715;" FontSize="10"
                                 Foreground="#CCCCCC"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Button>
                  </Panel>

                  <!-- Read-only lock icon -->
                  <TextBlock Grid.Column="3"
                             Text="&#x1F512;" FontSize="9"
                             VerticalAlignment="Center"
                             Margin="2,0"
                             IsVisible="{Binding IsReadOnly}"
                             ToolTip.Tip="Read Only"/>
                </Grid>
              </Border>

              <Border.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Close" InputGesture="Ctrl+W"
                            Command="{Binding $parent[UserControl].DataContext.CloseTabCommand}"
                            CommandParameter="{Binding}"/>
                  <MenuItem Header="Close Others"
                            Command="{Binding $parent[UserControl].DataContext.CloseOtherTabsCommand}"
                            CommandParameter="{Binding}"/>
                  <MenuItem Header="Close All"
                            Command="{Binding $parent[UserControl].DataContext.CloseAllTabsCommand}"/>
                  <MenuItem Header="Close to the Right"
                            Command="{Binding $parent[UserControl].DataContext.CloseTabsToTheRightCommand}"
                            CommandParameter="{Binding}"/>
                  <MenuItem Header="Close to the Left"
                            Command="{Binding $parent[UserControl].DataContext.CloseTabsToTheLeftCommand}"
                            CommandParameter="{Binding}"/>
                  <MenuItem Header="Close Saved"
                            Command="{Binding $parent[UserControl].DataContext.CloseSavedTabsCommand}"/>
                  <Separator/>
                  <MenuItem Header="Copy Path"
                            Command="{Binding $parent[UserControl].DataContext.CopyPathCommand}"
                            CommandParameter="{Binding}"/>
                  <MenuItem Header="Copy Relative Path"
                            Command="{Binding $parent[UserControl].DataContext.CopyRelativePathCommand}"
                            CommandParameter="{Binding}"/>
                  <Separator/>
                  <MenuItem Header="Reveal in Side Bar"
                            Command="{Binding $parent[UserControl].DataContext.RevealInSideBarCommand}"
                            CommandParameter="{Binding}"/>
                  <MenuItem Header="Open Containing Folder"
                            Command="{Binding $parent[UserControl].DataContext.OpenContainingFolderCommand}"
                            CommandParameter="{Binding}"/>
                  <Separator/>
                  <MenuItem Header="Pin Tab"
                            Command="{Binding $parent[UserControl].DataContext.PinTabCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding !IsPinned}"/>
                  <MenuItem Header="Unpin Tab"
                            Command="{Binding $parent[UserControl].DataContext.UnpinTabCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding IsPinned}"/>
                  <Separator/>
                  <MenuItem Header="Split Right"
                            Command="{Binding $parent[UserControl].DataContext.SplitRightCommand}"
                            CommandParameter="{Binding}"/>
                  <MenuItem Header="Split Down"
                            Command="{Binding $parent[UserControl].DataContext.SplitDownCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Overflow chevron button -->
    <Button Grid.Column="1"
            Classes="overflowBtn"
            IsVisible="{Binding HasOverflow}"
            Click="OnOverflowClick"
            ToolTip.Tip="Open tab list"
            AutomationProperties.Name="Tab overflow menu">
      <TextBlock Text="&#x00BB;" FontSize="16" FontWeight="Bold"/>
    </Button>

    <!-- Split editor button -->
    <Button Grid.Column="2"
            Classes="splitBtn"
            Click="OnSplitEditorClick"
            ToolTip.Tip="Split Editor Right (Ctrl+\)"
            AutomationProperties.Name="Split editor right">
      <TextBlock Text="&#x2503;&#x2503;" FontSize="11"/>
    </Button>
  </Grid>
</UserControl>
