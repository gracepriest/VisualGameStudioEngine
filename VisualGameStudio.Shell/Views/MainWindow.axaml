<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VisualGameStudio.Shell.ViewModels"
        xmlns:dock="using:Dock.Avalonia.Controls"
        xmlns:local="using:VisualGameStudio.Shell.Converters"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="VisualGameStudio.Shell.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

  <Window.KeyBindings>
    <KeyBinding Gesture="F5" Command="{Binding StartDebuggingCommand}"/>
    <KeyBinding Gesture="Ctrl+F5" Command="{Binding StartWithoutDebuggingCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+F5" Command="{Binding RestartDebuggingCommand}"/>
    <KeyBinding Gesture="Shift+F5" Command="{Binding StopDebuggingCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+P" Command="{Binding AttachToProcessCommand}"/>
    <KeyBinding Gesture="F9" Command="{Binding ToggleBreakpointCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+F9" Command="{Binding NewFunctionBreakpointCommand}"/>
    <KeyBinding Gesture="Ctrl+F10" Command="{Binding RunToCursorCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+F10" Command="{Binding SetNextStatementCommand}"/>
    <KeyBinding Gesture="F10" Command="{Binding StepOverCommand}"/>
    <KeyBinding Gesture="F11" Command="{Binding StepIntoCommand}"/>
    <KeyBinding Gesture="Shift+F11" Command="{Binding StepOutCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+B" Command="{Binding BuildCommand}"/>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAllCommand}"/>
    <KeyBinding Gesture="Ctrl+G" Command="{Binding GoToLineCommand}"/>
    <KeyBinding Gesture="Ctrl+T" Command="{Binding GoToSymbolCommand}"/>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FindCommand}"/>
    <KeyBinding Gesture="Ctrl+H" Command="{Binding ReplaceCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding ShowFindInFilesCommand}"/>
    <!-- Bookmark shortcuts -->
    <KeyBinding Gesture="Ctrl+K" Command="{Binding ToggleBookmarkCommand}"/>
    <KeyBinding Gesture="F2" Command="{Binding NextBookmarkCommand}"/>
    <KeyBinding Gesture="Shift+F2" Command="{Binding PreviousBookmarkCommand}"/>
    <!-- Navigation shortcuts -->
    <KeyBinding Gesture="F12" Command="{Binding GoToDefinitionCommand}"/>
    <KeyBinding Gesture="Ctrl+F12" Command="{Binding GoToImplementationCommand}"/>
    <KeyBinding Gesture="Shift+F12" Command="{Binding FindReferencesCommand}"/>
    <!-- Refactoring shortcuts -->
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RenameSymbolCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+M" Command="{Binding ExtractMethodCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+I" Command="{Binding InlineMethodCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding IntroduceVariableCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+OemMinus" Command="{Binding ChangeSignatureCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding EncapsulateFieldCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding MoveTypeToFileCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+X" Command="{Binding ExtractInterfaceCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+G" Command="{Binding GenerateConstructorCommand}"/>
    <KeyBinding Gesture="Ctrl+OemPeriod" Command="{Binding ImplementInterfaceCommand}"/>
    <!-- Error navigation shortcuts -->
    <KeyBinding Gesture="F8" Command="{Binding GoToNextErrorCommand}"/>
    <KeyBinding Gesture="Shift+F8" Command="{Binding GoToPreviousErrorCommand}"/>
    <!-- Panel shortcuts -->
    <KeyBinding Gesture="Ctrl+Alt+B" Command="{Binding ShowBreakpointsCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+O" Command="{Binding ShowOutputCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+E" Command="{Binding ShowErrorListCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+C" Command="{Binding ShowCallStackCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+V" Command="{Binding ShowVariablesCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+W" Command="{Binding ShowWatchCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+I" Command="{Binding ShowImmediateWindowCommand}"/>
    <KeyBinding Gesture="Ctrl+Alt+X" Command="{Binding ShowExceptionSettingsCommand}"/>
    <!-- Terminal shortcuts -->
    <KeyBinding Gesture="Ctrl+OemTilde" Command="{Binding ShowTerminalCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+OemTilde" Command="{Binding CreateNewTerminalCommand}"/>
    <!-- Command Palette -->
    <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding OpenCommandPaletteCommand}"/>
    <!-- Quick Open (File Search) -->
    <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenQuickOpenCommand}"/>
    <!-- Zen Mode -->
    <KeyBinding Gesture="Ctrl+Shift+Z" Command="{Binding ToggleZenModeCommand}"/>
    <!-- Show Whitespace -->
    <KeyBinding Gesture="Ctrl+Shift+W" Command="{Binding ToggleWhitespaceCommand}"/>
    <!-- Column Selection Mode -->
    <KeyBinding Gesture="Alt+Shift+Insert" Command="{Binding ToggleColumnSelectionModeCommand}"/>
    <!-- Panel focus shortcuts (keyboard navigation) -->
    <KeyBinding Gesture="Ctrl+D1" Command="{Binding FocusSolutionExplorerCommand}"/>
    <KeyBinding Gesture="Ctrl+D2" Command="{Binding FocusEditorCommand}"/>
    <KeyBinding Gesture="Ctrl+D3" Command="{Binding FocusOutputCommand}"/>
    <KeyBinding Gesture="Ctrl+D4" Command="{Binding FocusTerminalCommand}"/>
    <KeyBinding Gesture="Ctrl+D5" Command="{Binding FocusErrorListCommand}"/>
    <KeyBinding Gesture="Ctrl+D0" Command="{Binding FocusVariablesCommand}"/>
    <!-- Panel cycling (accessibility) -->
    <KeyBinding Gesture="F6" Command="{Binding FocusNextPanelCommand}"/>
    <KeyBinding Gesture="Shift+F6" Command="{Binding FocusPreviousPanelCommand}"/>
    <!-- Keyboard shortcuts help -->
    <KeyBinding Gesture="F1" Command="{Binding ShowKeyboardShortcutsCommand}"/>
    <!-- IDE zoom -->
    <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}"/>
    <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+D0" Command="{Binding ZoomResetCommand}"/>
  </Window.KeyBindings>

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid>
  <!-- Screen reader live regions (hidden, used by ScreenReaderService) -->
  <TextBlock x:Name="LiveRegionPolite"
             AutomationProperties.LiveSetting="Polite"
             AutomationProperties.Name="Status announcements"
             IsVisible="False"
             Width="1" Height="1"/>
  <TextBlock x:Name="LiveRegionAssertive"
             AutomationProperties.LiveSetting="Assertive"
             AutomationProperties.Name="Alert announcements"
             IsVisible="False"
             Width="1" Height="1"/>

  <DockPanel>
    <!-- Skip Navigation (visible only on focus for keyboard users) -->
    <Border DockPanel.Dock="Top" Height="0" ClipToBounds="True">
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,2">
        <Button Content="Skip to Editor"
                Command="{Binding FocusEditorCommand}"
                Classes="skipNavLink"
                AutomationProperties.Name="Skip to Code Editor"
                Focusable="True"/>
        <Button Content="Skip to Solution Explorer"
                Command="{Binding FocusSolutionExplorerCommand}"
                Classes="skipNavLink"
                AutomationProperties.Name="Skip to Solution Explorer"
                Focusable="True"/>
        <Button Content="Skip to Terminal"
                Command="{Binding FocusTerminalCommand}"
                Classes="skipNavLink"
                AutomationProperties.Name="Skip to Terminal"
                Focusable="True"/>
      </StackPanel>
    </Border>

    <!-- Menu Bar -->
    <Menu DockPanel.Dock="Top" IsVisible="{Binding !IsZenMode}"
          AutomationProperties.Name="Main Menu">
      <MenuItem Header="_File">
        <MenuItem Header="_New Project..." Command="{Binding NewProjectCommand}" InputGesture="Ctrl+Shift+N"/>
        <MenuItem Header="New _Solution..." Command="{Binding NewSolutionCommand}"/>
        <Separator/>
        <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}" InputGesture="Ctrl+Shift+O"/>
        <MenuItem Header="Open _Solution..." Command="{Binding OpenSolutionCommand}"/>
        <MenuItem Header="Open _File..." Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O"/>
        <MenuItem Header="Open F_older..." Command="{Binding OpenFolderCommand}"/>
        <MenuItem Header="Open _Workspace..." Command="{Binding OpenWorkspaceCommand}"/>
        <MenuItem Header="Open _Recent" ItemsSource="{Binding RecentProjectMenuItems}">
          <MenuItem.Styles>
            <Style Selector="MenuItem">
              <Setter Property="Header" Value="{Binding Header}"/>
              <Setter Property="Command" Value="{Binding Command}"/>
              <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
              <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
            </Style>
          </MenuItem.Styles>
        </MenuItem>
        <Separator/>
        <MenuItem Header="Add _New Project to Solution..." Command="{Binding AddNewProjectToSolutionCommand}" IsEnabled="{Binding HasSolutionOpen}"/>
        <MenuItem Header="Add E_xisting Project to Solution..." Command="{Binding AddExistingProjectToSolutionCommand}" IsEnabled="{Binding HasSolutionOpen}"/>
        <Separator/>
        <MenuItem Header="Add Folder to _Workspace..." Command="{Binding AddFolderToWorkspaceCommand}"/>
        <MenuItem Header="Save Workspace As..." Command="{Binding SaveWorkspaceAsCommand}"/>
        <Separator/>
        <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGesture="Ctrl+S"/>
        <MenuItem Header="Save _All" Command="{Binding SaveAllCommand}" InputGesture="Ctrl+Shift+S"/>
        <Separator/>
        <MenuItem Header="C_lose Solution" Command="{Binding CloseSolutionCommand}" IsEnabled="{Binding HasSolutionOpen}"/>
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGesture="Alt+F4"/>
      </MenuItem>

      <MenuItem Header="_Edit">
        <MenuItem Header="_Undo" InputGesture="Ctrl+Z"/>
        <MenuItem Header="_Redo" InputGesture="Ctrl+Y"/>
        <Separator/>
        <MenuItem Header="Cu_t" InputGesture="Ctrl+X"/>
        <MenuItem Header="_Copy" InputGesture="Ctrl+C"/>
        <MenuItem Header="_Paste" InputGesture="Ctrl+V"/>
        <Separator/>
        <MenuItem Header="_Find..." Command="{Binding FindCommand}" InputGesture="Ctrl+F"/>
        <MenuItem Header="_Replace..." Command="{Binding ReplaceCommand}" InputGesture="Ctrl+H"/>
        <MenuItem Header="Find in _Files..." Command="{Binding ShowFindInFilesCommand}" InputGesture="Ctrl+Shift+F"/>
        <Separator/>
        <MenuItem Header="_Go to Definition" Command="{Binding GoToDefinitionCommand}" InputGesture="F12"/>
        <MenuItem Header="Go to _Implementation" Command="{Binding GoToImplementationCommand}" InputGesture="Ctrl+F12"/>
        <MenuItem Header="Find All _References" Command="{Binding FindReferencesCommand}" InputGesture="Shift+F12"/>
        <MenuItem Header="_Rename Symbol..." Command="{Binding RenameSymbolCommand}" InputGesture="Ctrl+R"/>
        <MenuItem Header="_Extract Method..." Command="{Binding ExtractMethodCommand}" InputGesture="Ctrl+Shift+M"/>
        <MenuItem Header="_Inline Method..." Command="{Binding InlineMethodCommand}" InputGesture="Ctrl+Shift+I"/>
        <MenuItem Header="Introduce _Variable..." Command="{Binding IntroduceVariableCommand}" InputGesture="Ctrl+Shift+V"/>
        <MenuItem Header="Change _Signature..." Command="{Binding ChangeSignatureCommand}" InputGesture="Ctrl+Shift+-"/>
        <MenuItem Header="_Encapsulate Field..." Command="{Binding EncapsulateFieldCommand}" InputGesture="Ctrl+Shift+E"/>
        <MenuItem Header="_Move Type to File..." Command="{Binding MoveTypeToFileCommand}" InputGesture="Ctrl+Shift+T"/>
        <MenuItem Header="E_xtract Interface..." Command="{Binding ExtractInterfaceCommand}" InputGesture="Ctrl+Shift+X"/>
        <MenuItem Header="_Generate Constructor..." Command="{Binding GenerateConstructorCommand}" InputGesture="Ctrl+Shift+G"/>
        <MenuItem Header="_Implement Interface..." Command="{Binding ImplementInterfaceCommand}" InputGesture="Ctrl+."/>
        <Separator/>
        <MenuItem Header="Go to _Line..." Command="{Binding GoToLineCommand}" InputGesture="Ctrl+G"/>
        <MenuItem Header="Go to _Symbol..." Command="{Binding GoToSymbolCommand}" InputGesture="Ctrl+T"/>
        <Separator/>
        <MenuItem Header="_Bookmarks">
          <MenuItem Header="_Toggle Bookmark" Command="{Binding ToggleBookmarkCommand}" InputGesture="Ctrl+K"/>
          <MenuItem Header="_Next Bookmark" Command="{Binding NextBookmarkCommand}" InputGesture="F2"/>
          <MenuItem Header="_Previous Bookmark" Command="{Binding PreviousBookmarkCommand}" InputGesture="Shift+F2"/>
          <Separator/>
          <MenuItem Header="_Clear All Bookmarks" Command="{Binding ClearAllBookmarksCommand}"/>
          <MenuItem Header="_Show Bookmarks Panel" Command="{Binding ShowBookmarksCommand}"/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="Toggle _Comment" Command="{Binding ToggleCommentCommand}" InputGesture="Ctrl+OemQuestion"/>
        <Separator/>
        <MenuItem Header="_Line">
          <MenuItem Header="_Duplicate Line" Command="{Binding DuplicateLineCommand}" InputGesture="Ctrl+D"/>
          <MenuItem Header="Move Line _Up" Command="{Binding MoveLineUpCommand}" InputGesture="Alt+Up"/>
          <MenuItem Header="Move Line _Down" Command="{Binding MoveLineDownCommand}" InputGesture="Alt+Down"/>
          <Separator/>
          <MenuItem Header="De_lete Line" Command="{Binding DeleteLineCommand}" InputGesture="Ctrl+Shift+K"/>
        </MenuItem>
      </MenuItem>

      <MenuItem Header="_View">
        <MenuItem Header="_Command Palette..." Command="{Binding OpenCommandPaletteCommand}" InputGesture="Ctrl+Shift+P"/>
        <MenuItem Header="_Quick Open..." Command="{Binding OpenQuickOpenCommand}" InputGesture="Ctrl+P"/>
        <Separator/>
        <MenuItem Header="_Solution Explorer" Command="{Binding ShowSolutionExplorerCommand}"/>
        <MenuItem Header="_Output" Command="{Binding ShowOutputCommand}"/>
        <MenuItem Header="_Error List" Command="{Binding ShowErrorListCommand}"/>
        <MenuItem Header="_Next Error" Command="{Binding GoToNextErrorCommand}" InputGesture="F8"/>
        <MenuItem Header="Pre_vious Error" Command="{Binding GoToPreviousErrorCommand}" InputGesture="Shift+F8"/>
        <MenuItem Header="_Terminal" Command="{Binding ShowTerminalCommand}" InputGesture="Ctrl+OemTilde"/>
        <MenuItem Header="New Ter_minal" Command="{Binding CreateNewTerminalCommand}" InputGesture="Ctrl+Shift+OemTilde"/>
        <MenuItem Header="Find _Results" Command="{Binding ShowFindResultsCommand}"/>
        <Separator/>
        <MenuItem Header="Focus Solution E_xplorer" Command="{Binding FocusSolutionExplorerCommand}" InputGesture="Ctrl+1"/>
        <MenuItem Header="Focus _Editor" Command="{Binding FocusEditorCommand}" InputGesture="Ctrl+2"/>
        <MenuItem Header="Focus _Output" Command="{Binding FocusOutputCommand}" InputGesture="Ctrl+3"/>
        <MenuItem Header="Focus Ter_minal" Command="{Binding FocusTerminalCommand}" InputGesture="Ctrl+4"/>
        <MenuItem Header="Focus Error _List" Command="{Binding FocusErrorListCommand}" InputGesture="Ctrl+5"/>
        <MenuItem Header="Focus _Variables" Command="{Binding FocusVariablesCommand}" InputGesture="Ctrl+0"/>
        <Separator/>
        <MenuItem Header="Show _Whitespace" Command="{Binding ToggleWhitespaceCommand}" InputGesture="Ctrl+Shift+W">
          <MenuItem.Icon>
            <CheckBox IsChecked="{Binding ShowWhitespace}" IsHitTestVisible="False" BorderThickness="0" Padding="0" MinWidth="0"/>
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="Column Se_lection Mode" Command="{Binding ToggleColumnSelectionModeCommand}" InputGesture="Alt+Shift+Insert">
          <MenuItem.Icon>
            <CheckBox IsChecked="{Binding IsColumnSelectionMode}" IsHitTestVisible="False" BorderThickness="0" Padding="0" MinWidth="0"/>
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="_Zen Mode" Command="{Binding ToggleZenModeCommand}" InputGesture="Ctrl+Shift+Z"/>
        <MenuItem Header="_Full Screen" InputGesture="Shift+Alt+Enter"/>
      </MenuItem>

      <MenuItem Header="_Tools">
        <MenuItem Header="_Keyboard Shortcuts..." Command="{Binding ShowKeyboardShortcutsCommand}"/>
        <Separator/>
        <MenuItem Header="_Settings..." Command="{Binding SettingsCommand}"/>
      </MenuItem>

      <MenuItem Header="_Build">
        <MenuItem Header="Build _Solution" Command="{Binding BuildSolutionCommand}" IsEnabled="{Binding HasSolutionOpen}"/>
        <MenuItem Header="_Build Project" Command="{Binding BuildCommand}" InputGesture="Ctrl+Shift+B"/>
        <MenuItem Header="_Rebuild Project" Command="{Binding RebuildCommand}"/>
        <MenuItem Header="_Clean Project" Command="{Binding CleanCommand}"/>
        <Separator/>
        <MenuItem Header="Cancel Build" Command="{Binding CancelBuildCommand}"/>
      </MenuItem>

      <MenuItem Header="Te_rminal">
        <MenuItem Header="_New Terminal" Command="{Binding CreateNewTerminalCommand}" InputGesture="Ctrl+Shift+OemTilde"/>
        <MenuItem Header="_Split Terminal" Command="{Binding SplitTerminalCommand}"/>
        <Separator/>
        <MenuItem Header="Run _Task..." Command="{Binding RunTaskCommand}"/>
        <MenuItem Header="Run _Build Task" Command="{Binding RunBuildTaskCommand}" InputGesture="Ctrl+Shift+B"/>
        <MenuItem Header="Run _Test Task" Command="{Binding RunTestTaskCommand}"/>
        <Separator/>
        <MenuItem Header="_Configure Tasks..." Command="{Binding ConfigureTasksCommand}"/>
        <MenuItem Header="Configure Default _Shell..." Command="{Binding ConfigureDefaultShellCommand}"/>
      </MenuItem>

      <MenuItem Header="_Debug">
        <MenuItem Header="_Start Debugging" Command="{Binding StartDebuggingCommand}" InputGesture="F5"/>
        <MenuItem Header="Start _Without Debugging" Command="{Binding StartWithoutDebuggingCommand}" InputGesture="Ctrl+F5"/>
        <MenuItem Header="Run in _External Console" Command="{Binding RunInExternalConsoleCommand}"/>
        <MenuItem Header="_Restart Debugging" Command="{Binding RestartDebuggingCommand}" InputGesture="Ctrl+Shift+F5" IsEnabled="{Binding IsDebugging}"/>
        <MenuItem Header="_Stop Debugging" Command="{Binding StopDebuggingCommand}" InputGesture="Shift+F5"/>
        <MenuItem Header="_Attach to Process..." Command="{Binding AttachToProcessCommand}" InputGesture="Ctrl+Alt+P"/>
        <Separator/>
        <MenuItem Header="_Continue" Command="{Binding ContinueCommand}" InputGesture="F5" IsEnabled="{Binding IsPaused}"/>
        <MenuItem Header="Step _Over" Command="{Binding StepOverCommand}" InputGesture="F10" IsEnabled="{Binding IsPaused}"/>
        <MenuItem Header="Step _Into" Command="{Binding StepIntoCommand}" InputGesture="F11" IsEnabled="{Binding IsPaused}"/>
        <MenuItem Header="Step O_ut" Command="{Binding StepOutCommand}" InputGesture="Shift+F11" IsEnabled="{Binding IsPaused}"/>
        <MenuItem Header="_Run to Cursor" Command="{Binding RunToCursorCommand}" InputGesture="Ctrl+F10" IsEnabled="{Binding IsPaused}"/>
        <MenuItem Header="Set _Next Statement" Command="{Binding SetNextStatementCommand}" InputGesture="Ctrl+Shift+F10" IsEnabled="{Binding IsPaused}"/>
        <MenuItem Header="_Pause" Command="{Binding PauseCommand}" IsEnabled="{Binding IsDebugging}"/>
        <Separator/>
        <MenuItem Header="Toggle _Breakpoint" Command="{Binding ToggleBreakpointCommand}" InputGesture="F9"/>
        <MenuItem Header="New _Function Breakpoint..." Command="{Binding NewFunctionBreakpointCommand}" InputGesture="Ctrl+Shift+F9"/>
        <MenuItem Header="_Exception Settings..." Command="{Binding ShowExceptionSettingsCommand}" InputGesture="Ctrl+Alt+X"/>
        <Separator/>
        <MenuItem Header="Edit _Launch Configuration..." Command="{Binding EditLaunchConfigurationCommand}"/>
        <Separator/>
        <MenuItem Header="_Windows">
          <MenuItem Header="_Breakpoints" Command="{Binding ShowBreakpointsCommand}" InputGesture="Ctrl+Alt+B"/>
          <MenuItem Header="_Call Stack" Command="{Binding ShowCallStackCommand}" InputGesture="Ctrl+Alt+C"/>
          <MenuItem Header="_Variables" Command="{Binding ShowVariablesCommand}" InputGesture="Ctrl+Alt+V"/>
          <MenuItem Header="_Watch" Command="{Binding ShowWatchCommand}" InputGesture="Ctrl+Alt+W"/>
          <MenuItem Header="_Immediate" Command="{Binding ShowImmediateWindowCommand}" InputGesture="Ctrl+Alt+I"/>
        </MenuItem>
      </MenuItem>

      <MenuItem Header="_Help">
        <MenuItem Header="_About Visual Game Studio"/>
      </MenuItem>
    </Menu>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="4" BorderThickness="0,0,0,1" BorderBrush="#3C3C3C" IsVisible="{Binding !IsZenMode}"
            AutomationProperties.Name="Main Toolbar">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Classes="toolbarButton" Command="{Binding NewProjectCommand}" ToolTip.Tip="New Project"
                AutomationProperties.Name="New Project">
          <TextBlock Text="New" FontSize="12"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding OpenProjectCommand}" ToolTip.Tip="Open Project"
                AutomationProperties.Name="Open Project">
          <TextBlock Text="Open" FontSize="12"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding SaveCommand}" ToolTip.Tip="Save"
                AutomationProperties.Name="Save">
          <TextBlock Text="Save" FontSize="12"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding SaveAllCommand}" ToolTip.Tip="Save All"
                AutomationProperties.Name="Save All">
          <TextBlock Text="Save All" FontSize="12"/>
        </Button>

        <Border Width="1" Background="#3C3C3C" Margin="4,2"/>

        <ComboBox ItemsSource="{Binding Configurations}"
                  SelectedItem="{Binding CurrentConfiguration}"
                  MinWidth="100"
                  Margin="4,0"
                  AutomationProperties.Name="Build Configuration"
                  AutomationProperties.HelpText="Select build configuration such as Debug or Release"/>

        <Button Classes="toolbarButton" Command="{Binding BuildCommand}" ToolTip.Tip="Build"
                AutomationProperties.Name="Build Project">
          <TextBlock Text="Build" FontSize="12"/>
        </Button>

        <Border Width="1" Background="#3C3C3C" Margin="4,2"/>

        <!-- Debug Toolbar -->
        <Button Classes="toolbarButton" Command="{Binding StartDebuggingCommand}" ToolTip.Tip="Start Debugging (F5)" IsVisible="{Binding !IsDebugging}"
                AutomationProperties.Name="Start Debugging"
                AutomationProperties.HelpText="Start debugging the project, shortcut F5">
          <TextBlock Text="▶ Start" FontSize="12" Foreground="#89D185"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding ContinueCommand}" ToolTip.Tip="Continue (F5)" IsVisible="{Binding IsPaused}"
                AutomationProperties.Name="Continue Debugging"
                AutomationProperties.HelpText="Continue execution, shortcut F5">
          <TextBlock Text="▶ Continue" FontSize="12" Foreground="#89D185"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding PauseCommand}" ToolTip.Tip="Pause" IsVisible="{Binding IsDebugging}" IsEnabled="{Binding !IsPaused}"
                AutomationProperties.Name="Pause Debugging"
                AutomationProperties.HelpText="Pause program execution">
          <TextBlock Text="⏸" FontSize="12" Foreground="#DCDCAA"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding StopDebuggingCommand}" ToolTip.Tip="Stop Debugging (Shift+F5)" IsVisible="{Binding IsDebugging}"
                AutomationProperties.Name="Stop Debugging"
                AutomationProperties.HelpText="Stop debugging the project, shortcut Shift+F5">
          <TextBlock Text="■" FontSize="12" Foreground="#E51400"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding RestartDebuggingCommand}" ToolTip.Tip="Restart Debugging (Ctrl+Shift+F5)" IsVisible="{Binding IsDebugging}"
                AutomationProperties.Name="Restart Debugging"
                AutomationProperties.HelpText="Restart the debugging session, shortcut Ctrl+Shift+F5">
          <TextBlock Text="⟳" FontSize="14" Foreground="#89D185"/>
        </Button>

        <Border Width="1" Background="#3C3C3C" Margin="4,2" IsVisible="{Binding IsDebugging}"/>

        <Button Classes="toolbarButton" Command="{Binding StepOverCommand}" ToolTip.Tip="Step Over (F10)" IsVisible="{Binding IsPaused}"
                AutomationProperties.Name="Step Over"
                AutomationProperties.HelpText="Step over the current line, shortcut F10">
          <TextBlock Text="⤵" FontSize="14"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding StepIntoCommand}" ToolTip.Tip="Step Into (F11)" IsVisible="{Binding IsPaused}"
                AutomationProperties.Name="Step Into"
                AutomationProperties.HelpText="Step into the current function call, shortcut F11">
          <TextBlock Text="↓" FontSize="14"/>
        </Button>
        <Button Classes="toolbarButton" Command="{Binding StepOutCommand}" ToolTip.Tip="Step Out (Shift+F11)" IsVisible="{Binding IsPaused}"
                AutomationProperties.Name="Step Out"
                AutomationProperties.HelpText="Step out of the current function, shortcut Shift+F11">
          <TextBlock Text="↑" FontSize="14"/>
        </Button>

        <!-- Debug Status -->
        <TextBlock Text="{Binding DebugStatusText}" Foreground="#DCDCAA" VerticalAlignment="Center" Margin="8,0" IsVisible="{Binding IsDebugging}"
                   AutomationProperties.Name="Debug Status"/>
      </StackPanel>
    </Border>

    <!-- Status Bar (orange during debug, blue normally) -->
    <Border DockPanel.Dock="Bottom" Classes="statusBar" IsVisible="{Binding !IsZenMode}"
            Background="{Binding IsDebugging, Converter={x:Static local:BoolToBrushConverter.DebugStatusBarInstance}}"
            AutomationProperties.Name="Status Bar">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <!-- Status message -->
        <TextBlock Grid.Column="0"
                   Text="{Binding StatusText}"
                   VerticalAlignment="Center"
                   Margin="8,0"
                   Foreground="White"
                   AutomationProperties.Name="Status Message"/>

        <!-- Git blame annotation for current line -->
        <TextBlock Grid.Column="1"
                   Text="{Binding BlameAnnotationText}"
                   VerticalAlignment="Center"
                   Margin="12,0,8,0"
                   Foreground="#808080"
                   FontSize="11"
                   MaxWidth="400"
                   TextTrimming="CharacterEllipsis"
                   IsVisible="{Binding BlameAnnotationText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   ToolTip.Tip="Git blame for current line"
                   AutomationProperties.Name="Git Blame Annotation"/>

        <!-- Spacer -->
        <Border Grid.Column="2"/>

        <!-- Diagnostic counts (errors + warnings) - clickable to open Error List -->
        <Border Grid.Column="3" Padding="6,0" Cursor="Hand"
                Background="Transparent"
                PointerPressed="OnDiagnosticCountsClicked"
                ToolTip.Tip="Show Error List (Ctrl+Alt+E)"
                AutomationProperties.Name="Diagnostic Counts"
                AutomationProperties.HelpText="Show Error List (Ctrl+Alt+E)">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
            <!-- Error count -->
            <StackPanel Orientation="Horizontal" Spacing="3">
              <Border Width="14" Height="14" CornerRadius="7"
                      Background="#E51400" VerticalAlignment="Center">
                <TextBlock Text="x" Foreground="White" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,-1,0,0"/>
              </Border>
              <TextBlock Text="{Binding ErrorList.ErrorCount}"
                         Foreground="{Binding ErrorList.ErrorCount, Converter={x:Static local:DiagnosticCountColorConverter.ErrorInstance}}"
                         VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
            <!-- Warning count -->
            <StackPanel Orientation="Horizontal" Spacing="3">
              <TextBlock Text="&#x26A0;" Foreground="#F0AD4E" FontSize="13"
                         VerticalAlignment="Center" Margin="0,-1,0,0"/>
              <TextBlock Text="{Binding ErrorList.WarningCount}"
                         Foreground="{Binding ErrorList.WarningCount, Converter={x:Static local:DiagnosticCountColorConverter.WarningInstance}}"
                         VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
            <!-- Info count (only visible when > 0) -->
            <StackPanel Orientation="Horizontal" Spacing="3"
                        IsVisible="{Binding ErrorList.MessageCount, Converter={x:Static local:PositiveIntToBoolConverter.Instance}}">
              <TextBlock Text="&#x2139;" Foreground="#58A6FF" FontSize="13"
                         VerticalAlignment="Center" Margin="0,-1,0,0"/>
              <TextBlock Text="{Binding ErrorList.MessageCount}"
                         Foreground="#58A6FF"
                         VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Notification Center Bell -->
        <Button Grid.Column="4" Classes="statusBarButton"
                Command="{Binding StatusBar.ShowNotificationsCommand}"
                AutomationProperties.Name="Notification Center"
                AutomationProperties.HelpText="Show notification center"
                ToolTip.Tip="Notifications">
          <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
            <TextBlock Text="&#x1F514;" FontSize="13" VerticalAlignment="Center"/>
            <Border CornerRadius="7" Background="#E51400" MinWidth="14" Height="14"
                    IsVisible="{Binding StatusBar.NotificationCount, Converter={x:Static local:PositiveIntToBoolConverter.Instance}}"
                    VerticalAlignment="Center" Padding="3,0">
              <TextBlock Text="{Binding StatusBar.NotificationCount}" Foreground="White"
                         FontSize="9" FontWeight="Bold"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </StackPanel>
        </Button>

        <!-- Build configuration -->
        <TextBlock Grid.Column="5"
                   Text="{Binding CurrentConfiguration}"
                   VerticalAlignment="Center"
                   Margin="8,0"
                   Foreground="White"
                   AutomationProperties.Name="Build Configuration"/>

        <!-- Caret position -->
        <TextBlock Grid.Column="6"
                   VerticalAlignment="Center"
                   Margin="8,0"
                   Foreground="White"
                   AutomationProperties.Name="Caret Position">
          <TextBlock.Text>
            <MultiBinding StringFormat="Ln {0}, Col {1}">
              <Binding Path="CaretLine"/>
              <Binding Path="CaretColumn"/>
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>

        <!-- Indentation indicator (keyboard-focusable button) -->
        <Button Grid.Column="7" Classes="statusBarButton"
                Click="OnIndentationButtonClick"
                AutomationProperties.Name="Indentation Settings"
                AutomationProperties.HelpText="Click or press Enter to change indentation settings"
                ToolTip.Tip="Click to change indentation settings (Tab to focus)">
          <TextBlock Text="{Binding StatusBar.Indentation}"
                     VerticalAlignment="Center"
                     Foreground="#BBBBBB"/>
        </Button>

        <!-- Encoding indicator (keyboard-focusable button) -->
        <Button Grid.Column="8" Classes="statusBarButton"
                Click="OnEncodingButtonClick"
                AutomationProperties.Name="File Encoding"
                AutomationProperties.HelpText="Click or press Enter to change file encoding"
                ToolTip.Tip="Click to change file encoding (Tab to focus)">
          <TextBlock Text="{Binding StatusBar.Encoding}"
                     VerticalAlignment="Center"
                     Foreground="#BBBBBB"/>
        </Button>

        <!-- Line ending indicator (keyboard-focusable button) -->
        <Button Grid.Column="9" Classes="statusBarButton"
                Click="OnLineEndingButtonClick"
                AutomationProperties.Name="Line Ending Style"
                AutomationProperties.HelpText="Click or press Enter to change line ending style"
                ToolTip.Tip="Click to change line ending style (Tab to focus)">
          <TextBlock Text="{Binding StatusBar.LineEnding}"
                     VerticalAlignment="Center"
                     Foreground="#BBBBBB"/>
        </Button>

        <!-- Language mode indicator (keyboard-focusable button) -->
        <Button Grid.Column="10" Classes="statusBarButton"
                Click="OnLanguageModeButtonClick"
                AutomationProperties.Name="Language Mode"
                AutomationProperties.HelpText="Current language mode"
                ToolTip.Tip="Current language mode (Tab to focus)">
          <TextBlock Text="{Binding StatusBar.LanguageMode}"
                     VerticalAlignment="Center"
                     Foreground="#569CD6"/>
        </Button>

        <!-- Zoom level indicator (keyboard-focusable button) -->
        <Button Grid.Column="11" Classes="statusBarButton"
                Command="{Binding ZoomResetCommand}"
                AutomationProperties.Name="Zoom Level"
                AutomationProperties.HelpText="Current zoom level. Click to reset to 100%. Use Ctrl+Plus/Minus to zoom."
                ToolTip.Tip="Click to reset zoom (Ctrl+0)">
          <TextBlock VerticalAlignment="Center"
                     Foreground="#BBBBBB"
                     FontSize="11">
            <TextBlock.Text>
              <MultiBinding StringFormat="{}{0}%">
                <Binding Path="ZoomLevel"/>
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </Button>

        <!-- Ctrl+Shift+P hint (keyboard-focusable button) -->
        <Button Grid.Column="12" Classes="statusBarButton"
                Command="{Binding OpenCommandPaletteCommand}"
                AutomationProperties.Name="Open Command Palette (Ctrl+Shift+P)"
                AutomationProperties.HelpText="Open the command palette"
                ToolTip.Tip="Open Command Palette (Ctrl+Shift+P)">
          <TextBlock Text="Ctrl+Shift+P"
                     VerticalAlignment="Center"
                     Foreground="#606060"
                     FontSize="11"/>
        </Button>
      </Grid>
    </Border>

    <!-- Main Content - Dock Control -->
    <dock:DockControl Layout="{Binding Layout}"/>

  </DockPanel>

  <!-- Notification Center Flyout -->
  <Border Name="NotificationCenterPanel"
          HorizontalAlignment="Right"
          VerticalAlignment="Bottom"
          Margin="0,0,10,35"
          Width="380"
          MaxHeight="500"
          Background="#252526"
          BorderBrush="#3C3C3C"
          BorderThickness="1"
          CornerRadius="6"
          IsVisible="{Binding StatusBar.IsNotificationCenterOpen}"
          BoxShadow="0 4 16 #40000000"
          AutomationProperties.Name="Notification Center">
    <DockPanel>
      <!-- Header -->
      <Border DockPanel.Dock="Top" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#3C3C3C">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Notifications" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Content="Clear All"
                  Command="{Binding StatusBar.ClearAllNotificationsCommand}"
                  FontSize="11" Padding="8,3"
                  Background="Transparent" Foreground="#58A6FF" BorderThickness="0"
                  Cursor="Hand"/>
        </Grid>
      </Border>
      <!-- Notification list -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="440">
        <ItemsControl ItemsSource="{Binding StatusBar.Notifications}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#2D2D2D"
                      Background="Transparent" Cursor="Hand">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <!-- Severity icon -->
                  <TextBlock Grid.Column="0" Text="{Binding SeverityIcon}" FontSize="14"
                             Foreground="{Binding SeverityColor}" VerticalAlignment="Top"
                             Margin="0,2,8,0"/>
                  <!-- Message and time -->
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{Binding Message}" Foreground="#CCCCCC" FontSize="12"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Source}" Foreground="#606060" FontSize="10"/>
                      <TextBlock Text="{Binding TimeText}" Foreground="#606060" FontSize="10"/>
                    </StackPanel>
                  </StackPanel>
                  <!-- Dismiss button -->
                  <Button Grid.Column="2" Content="&#x2715;" FontSize="10" Padding="4,2"
                          Background="Transparent" Foreground="#606060" BorderThickness="0"
                          Command="{Binding $parent[Window].DataContext.StatusBar.DismissNotificationCommand}"
                          CommandParameter="{Binding}"
                          VerticalAlignment="Top" Cursor="Hand"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </DockPanel>
  </Border>

  <!-- Toast Notification Overlay -->
  <StackPanel Name="NotificationArea"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,20,40"
              MaxWidth="420"
              Spacing="5"
              IsHitTestVisible="True"
              AutomationProperties.Name="Notifications"
              AutomationProperties.LiveSetting="Assertive"/>
  </Grid>
</Window>
