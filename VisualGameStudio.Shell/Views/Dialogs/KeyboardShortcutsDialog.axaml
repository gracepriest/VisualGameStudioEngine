<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Dialogs"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
        x:Class="VisualGameStudio.Shell.Views.Dialogs.KeyboardShortcutsDialog"
        x:DataType="vm:KeyboardShortcutsViewModel"
        Title="Keyboard Shortcuts"
        Width="700" Height="500"
        MinWidth="500" MinHeight="350"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Search Bar -->
    <Border Grid.Row="0" Background="#2D2D2D" Padding="12" BorderThickness="0,0,0,1" BorderBrush="#3C3C3C">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Grid.Column="0"
                   Text="&#xE721;"
                   FontFamily="Segoe MDL2 Assets"
                   FontSize="16"
                   Foreground="#808080"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
        <TextBox Grid.Column="1"
                 x:Name="SearchBox"
                 Text="{Binding SearchText, Mode=TwoWay}"
                 Watermark="Search commands, keybindings, or categories..."
                 FontSize="14"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="#CCCCCC"/>
      </Grid>
    </Border>

    <!-- Keybindings DataGrid -->
    <DataGrid Grid.Row="1"
              ItemsSource="{Binding FilteredEntries}"
              SelectedItem="{Binding SelectedEntry}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserReorderColumns="False"
              CanUserSortColumns="True"
              CanUserResizeColumns="True"
              GridLinesVisibility="Horizontal"
              Background="#1E1E1E"
              HeadersVisibility="Column"
              BorderThickness="0">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Command"
                            Binding="{Binding Command}"
                            Width="2*"/>
        <DataGridTextColumn Header="Keybinding"
                            Binding="{Binding Keybinding}"
                            Width="*"/>
        <DataGridTextColumn Header="Category"
                            Binding="{Binding Category}"
                            Width="*"/>
      </DataGrid.Columns>
      <DataGrid.Styles>
        <Style Selector="DataGridRow">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
          <Setter Property="Fill" Value="#2A2D2E"/>
        </Style>
        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
          <Setter Property="Fill" Value="#094771"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
          <Setter Property="Background" Value="#252526"/>
          <Setter Property="Foreground" Value="#808080"/>
          <Setter Property="FontSize" Value="12"/>
          <Setter Property="Padding" Value="8,6"/>
          <Setter Property="BorderThickness" Value="0,0,1,1"/>
          <Setter Property="BorderBrush" Value="#3C3C3C"/>
        </Style>
        <Style Selector="DataGridCell">
          <Setter Property="FontSize" Value="13"/>
          <Setter Property="Padding" Value="8,4"/>
        </Style>
      </DataGrid.Styles>
    </DataGrid>

    <!-- Footer -->
    <Border Grid.Row="2"
            Background="#2D2D2D"
            Padding="12,8"
            BorderThickness="0,1,0,0"
            BorderBrush="#3C3C3C">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{Binding StatusText}"
                   FontSize="12"
                   Foreground="#808080"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1"
                Content="Close"
                Command="{Binding CloseCommand}"
                Width="80"
                HorizontalContentAlignment="Center"/>
      </Grid>
    </Border>

  </Grid>
</Window>
