<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Dialogs"
        xmlns:views="using:VisualGameStudio.Shell.Views.Dialogs"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="700"
        x:Class="VisualGameStudio.Shell.Views.Dialogs.SettingsDialog"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="960" Height="700"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource IdeBg}">

    <!-- Top Bar: Search + Scope Tabs + JSON toggle -->
    <Border Grid.Row="0" Padding="12,10" Background="{DynamicResource IdePanelBg}"
            BorderThickness="0,0,0,1" BorderBrush="{DynamicResource IdeFooterBorder}">
      <Grid RowDefinitions="Auto,Auto">
        <!-- Row 0: Scope tabs + Open JSON button -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="0,0,0,8">
          <Button Grid.Column="0" Content="User"
                  Command="{Binding SwitchToUserScopeCommand}"
                  Padding="12,4" Margin="0,0,4,0"
                  FontSize="12" FontWeight="{Binding IsUserScopeActive, Converter={x:Static views:SettingsDialog.BoldIfTrue}}"
                  Background="{Binding IsUserScopeActive, Converter={x:Static views:SettingsDialog.ScopeTabBg}}"
                  Foreground="{Binding IsUserScopeActive, Converter={x:Static views:SettingsDialog.ScopeTabFg}}"
                  CornerRadius="3"/>
          <Button Grid.Column="1" Content="Workspace"
                  Command="{Binding SwitchToWorkspaceScopeCommand}"
                  IsEnabled="{Binding HasWorkspace}"
                  Padding="12,4" Margin="0,0,4,0"
                  FontSize="12" FontWeight="{Binding IsWorkspaceScopeActive, Converter={x:Static views:SettingsDialog.BoldIfTrue}}"
                  Background="{Binding IsWorkspaceScopeActive, Converter={x:Static views:SettingsDialog.ScopeTabBg}}"
                  Foreground="{Binding IsWorkspaceScopeActive, Converter={x:Static views:SettingsDialog.ScopeTabFg}}"
                  CornerRadius="3"/>

          <!-- Spacer -->
          <Panel Grid.Column="2"/>

          <!-- @modified filter -->
          <Button Grid.Column="3" Content="Modified"
                  Command="{Binding ShowModifiedOnlyCommand}"
                  Padding="8,4" Margin="0,0,4,0"
                  FontSize="11"
                  Background="Transparent" BorderThickness="1" BorderBrush="#3794FF"
                  Foreground="#3794FF" CornerRadius="3"
                  ToolTip.Tip="Show only modified settings (@modified)"/>

          <!-- Open Settings JSON -->
          <Button Grid.Column="4" Content="{}{} Open Settings (JSON)"
                  Command="{Binding OpenSettingsJsonCommand}"
                  Padding="8,4" Margin="0,0,4,0"
                  FontSize="11"
                  Background="Transparent" BorderThickness="1"
                  BorderBrush="{DynamicResource IdeFooterBorder}"
                  CornerRadius="3"
                  ToolTip.Tip="Edit settings as JSON"/>

          <!-- Reset All -->
          <Button Grid.Column="5"
                  Content="Reset All"
                  Command="{Binding ResetToDefaultsCommand}"
                  Padding="8,4"
                  FontSize="11"
                  Background="Transparent" BorderThickness="1"
                  BorderBrush="{DynamicResource IdeFooterBorder}"
                  CornerRadius="3"
                  ToolTip.Tip="Reset all settings to defaults"/>
        </Grid>

        <!-- Row 1: Search box -->
        <Border Grid.Row="1" Padding="6" Background="{DynamicResource IdeBg}" CornerRadius="4">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="4,0,8,0"
                       FontSize="12" Opacity="0.5"/>
            <TextBox Grid.Column="1"
                     Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="Search settings (e.g. font, theme, @modified)..."
                     BorderThickness="0"
                     Background="Transparent"
                     FontSize="13"/>
            <Button Grid.Column="2"
                    Content="X"
                    Command="{Binding ClearSearchCommand}"
                    IsVisible="{Binding IsSearchActive}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8,4"
                    FontSize="11"
                    VerticalAlignment="Center"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <!-- Main Content Area -->
    <Panel Grid.Row="1">

      <!-- ===== JSON Editor View ===== -->
      <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsJsonEditorActive}" Margin="16">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <TextBlock Text="Settings JSON" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding UserSettingsPath}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"
                     IsVisible="{Binding IsUserScopeActive}"/>
          <TextBlock Text="{Binding WorkspaceSettingsPath}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"
                     IsVisible="{Binding IsWorkspaceScopeActive}"/>
        </StackPanel>

        <TextBox Grid.Row="1"
                 Text="{Binding JsonEditorContent, Mode=TwoWay}"
                 AcceptsReturn="True"
                 FontFamily="Cascadia Code, Consolas, monospace"
                 FontSize="13"
                 TextWrapping="NoWrap"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Content="Save JSON" Command="{Binding SaveJsonEditorCommand}" Classes="accent" Padding="12,6"/>
          <Button Content="Validate" Command="{Binding ValidateJsonEditorCommand}" Padding="12,6"/>
          <Button Content="Back to UI" Command="{Binding ToggleJsonEditorCommand}" Padding="12,6"/>
          <ItemsControl ItemsSource="{Binding JsonValidationErrors}" Margin="8,0,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" FontSize="11" Foreground="#E5534B" VerticalAlignment="Center"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Grid>

      <!-- ===== Search Results View ===== -->
      <ScrollViewer IsVisible="{Binding IsSearchActive}" Margin="16"
                    x:Name="SearchResultsScroller">
        <StackPanel>
          <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                     Text="{Binding FilteredSettings.Count, StringFormat='Showing {0} settings', Mode=OneWay}"/>
          <ItemsControl ItemsSource="{Binding FilteredSettings}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SearchableSettingItem">
                <Border Background="{DynamicResource IdePanelBg}" CornerRadius="4" Margin="0,0,0,6"
                        BorderThickness="{Binding IsModified, Converter={x:Static vm:ModifiedBorderConverter.Instance}}"
                        BorderBrush="#3794FF" Padding="0">
                  <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto" Margin="14,10">
                    <!-- Setting name + category badge + scope badge -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                      <Border Background="{DynamicResource IdeFooterBg}" CornerRadius="3" Padding="6,2">
                        <TextBlock Text="{Binding Category}" FontSize="10" Opacity="0.7"/>
                      </Border>
                      <Border Background="#264F78" CornerRadius="3" Padding="6,2"
                              IsVisible="{Binding ScopeBadge, Converter={x:Static vm:ScopeBadgeVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding ScopeBadge}" FontSize="10" Foreground="#CCC"/>
                      </Border>
                      <Border Background="#3794FF" CornerRadius="3" Padding="6,2" IsVisible="{Binding IsModified}">
                        <TextBlock Text="Modified" FontSize="10" Foreground="White"/>
                      </Border>
                    </StackPanel>

                    <!-- Setting key path -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding Key}" FontSize="11" Opacity="0.4" Margin="0,2,0,2"
                               FontFamily="Cascadia Code, Consolas, monospace"/>

                    <!-- Control -->
                    <Panel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                      <ToggleSwitch IsChecked="{Binding BoolValue}" IsVisible="{Binding IsCheckBox}"
                                    OnContent="" OffContent="" Padding="0" Margin="0"/>
                      <NumericUpDown Value="{Binding IntValue}"
                                    Minimum="{Binding Minimum}" Maximum="{Binding Maximum}" Increment="{Binding Increment}"
                                    Width="110" IsVisible="{Binding IsNumericUpDown}"/>
                      <ComboBox ItemsSource="{Binding Choices}" SelectedItem="{Binding StringValue}"
                                MinWidth="170" IsVisible="{Binding IsComboBox}"/>
                      <TextBox Text="{Binding StringValue, Mode=TwoWay}"
                               MinWidth="200" IsVisible="{Binding IsTextBox}"/>
                    </Panel>

                    <!-- Reset button -->
                    <Button Grid.Row="0" Grid.Column="2"
                            Content="Reset" Command="{Binding ResetToDefaultCommand}"
                            IsVisible="{Binding IsModified}"
                            FontSize="11" Padding="8,3" Margin="4,0,0,0"
                            Background="Transparent" Foreground="#3794FF"
                            BorderThickness="1" BorderBrush="#3794FF" CornerRadius="3"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Reset to default value"/>

                    <!-- Description -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                               Text="{Binding Description}" FontSize="12" Opacity="0.6"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <!-- ===== Category Sidebar + Settings View ===== -->
      <Grid ColumnDefinitions="200,*"
            IsVisible="{Binding !IsSearchActive}"
            x:Name="CategoryView">

        <!-- Make the whole grid invisible when JSON editor is active -->

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource IdePanelBg}"
                BorderThickness="0,0,1,0" BorderBrush="{DynamicResource IdeFooterBorder}"
                IsVisible="{Binding !IsJsonEditorActive}">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Categories}" Margin="0,4">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SettingsCategoryItem">
                  <Button Command="{Binding $parent[ItemsControl].DataContext.SelectCategoryCommand}"
                          CommandParameter="{Binding Id}"
                          Background="{Binding IsSelected, Converter={x:Static views:SettingsDialog.CategoryBg}}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Padding="12,8" Margin="4,1"
                          CornerRadius="4"
                          BorderThickness="0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"
                                 Margin="0,0,10,0" Opacity="0.7" Width="20" TextAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"
                                 FontWeight="{Binding IsSelected, Converter={x:Static views:SettingsDialog.BoldIfTrue}}"/>
                      <Border Grid.Column="2" Background="#3794FF" CornerRadius="8" Padding="6,2" MinWidth="20"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              IsVisible="{Binding ModifiedCount, Converter={x:Static vm:ModifiedCountVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding ModifiedCount}" FontSize="10" Foreground="White"
                                   HorizontalAlignment="Center"/>
                      </Border>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- Right Content: Settings for selected category -->
        <ScrollViewer Grid.Column="1" Margin="0" IsVisible="{Binding !IsJsonEditorActive}">
          <StackPanel Margin="20,12,20,20">
            <!-- Category title -->
            <TextBlock Text="{Binding SelectedCategory.Name}" FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,16"/>

            <!-- Keyboard category special view -->
            <DockPanel IsVisible="False" x:Name="KeyboardPanel">
              <!-- Handled in code-behind -->
            </DockPanel>

            <!-- Settings list for category -->
            <ItemsControl ItemsSource="{Binding CategorySettings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SearchableSettingItem">
                  <Border Background="{DynamicResource IdePanelBg}" CornerRadius="4" Margin="0,0,0,6"
                          BorderThickness="{Binding IsModified, Converter={x:Static vm:ModifiedBorderConverter.Instance}}"
                          BorderBrush="#3794FF">
                    <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto" Margin="14,10">
                      <!-- Setting name + badges -->
                      <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        <Border Background="#264F78" CornerRadius="3" Padding="6,2"
                                IsVisible="{Binding ScopeBadge, Converter={x:Static vm:ScopeBadgeVisibilityConverter.Instance}}">
                          <TextBlock Text="{Binding ScopeBadge}" FontSize="10" Foreground="#CCC"/>
                        </Border>
                        <Border Background="#3794FF" CornerRadius="3" Padding="4,1" IsVisible="{Binding IsModified}">
                          <TextBlock Text="Modified" FontSize="9" Foreground="White"/>
                        </Border>
                      </StackPanel>

                      <!-- Setting key -->
                      <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                 Text="{Binding Key}" FontSize="11" Opacity="0.35"
                                 FontFamily="Cascadia Code, Consolas, monospace" Margin="0,2,0,2"/>

                      <!-- Control -->
                      <Panel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                        <ToggleSwitch IsChecked="{Binding BoolValue}" IsVisible="{Binding IsCheckBox}"
                                      OnContent="" OffContent="" Padding="0" Margin="0"/>
                        <NumericUpDown Value="{Binding IntValue}"
                                      Minimum="{Binding Minimum}" Maximum="{Binding Maximum}" Increment="{Binding Increment}"
                                      Width="110" IsVisible="{Binding IsNumericUpDown}"/>
                        <ComboBox ItemsSource="{Binding Choices}" SelectedItem="{Binding StringValue}"
                                  MinWidth="170" IsVisible="{Binding IsComboBox}"/>
                        <TextBox Text="{Binding StringValue, Mode=TwoWay}"
                                 MinWidth="200" IsVisible="{Binding IsTextBox}"/>
                      </Panel>

                      <!-- Reset button -->
                      <Button Grid.Row="0" Grid.Column="2"
                              Content="Reset" Command="{Binding ResetToDefaultCommand}"
                              IsVisible="{Binding IsModified}"
                              FontSize="11" Padding="8,3" Margin="4,0,0,0"
                              Background="Transparent" Foreground="#3794FF"
                              BorderThickness="1" BorderBrush="#3794FF" CornerRadius="3"
                              VerticalAlignment="Center"
                              ToolTip.Tip="Reset to default value"/>

                      <!-- Description -->
                      <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                 Text="{Binding Description}" FontSize="12" Opacity="0.6"
                                 TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Keyboard shortcuts (shown only for Keyboard category) -->
            <DockPanel IsVisible="{Binding SelectedCategory.Id, Converter={x:Static views:SettingsDialog.IsKeyboardCategory}}"
                       Margin="0,8,0,0">
              <DataGrid ItemsSource="{Binding Shortcuts}"
                        AutoGenerateColumns="False"
                        IsReadOnly="False"
                        CanUserReorderColumns="False"
                        CanUserSortColumns="False"
                        GridLinesVisibility="Horizontal"
                        Background="{DynamicResource IdePanelBg}"
                        MaxHeight="400">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Action" Binding="{Binding Action}" IsReadOnly="True" Width="200"/>
                  <DataGridTextColumn Header="Shortcut" Binding="{Binding CurrentBinding}" Width="150"/>
                  <DataGridTextColumn Header="Default" Binding="{Binding DefaultBinding}" IsReadOnly="True" Width="150"/>
                </DataGrid.Columns>
              </DataGrid>
            </DockPanel>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Panel>

    <!-- Bottom Bar -->
    <Border Grid.Row="2"
            Background="{DynamicResource IdeFooterBg}"
            Padding="16,10"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource IdeFooterBorder}">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
        <!-- Settings file path -->
        <TextBlock Grid.Column="0" FontSize="11" Opacity="0.5" VerticalAlignment="Center"
                   Text="{Binding UserSettingsPath, Mode=OneWay}"/>

        <Panel Grid.Column="1"/>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
          <Button Content="OK"
                  Command="{Binding SaveCommand}"
                  Width="80" Classes="accent"/>
          <Button Content="Cancel"
                  Command="{Binding CancelCommand}"
                  Width="80"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
