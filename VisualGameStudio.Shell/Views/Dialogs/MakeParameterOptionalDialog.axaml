<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Dialogs"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="580"
        x:Class="VisualGameStudio.Shell.Views.Dialogs.MakeParameterOptionalDialog"
        x:DataType="vm:MakeParameterOptionalDialogViewModel"
        Title="Make Parameter Optional"
        Width="500" Height="580"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource IdeBg}">

  <DockPanel Margin="16">
    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
      <TextBlock Text="Make Parameter Optional" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource IdeFg}"/>
      <TextBlock Foreground="{DynamicResource IdeFgMuted}" Margin="0,4,0,0">
        <TextBlock.Text>
          <MultiBinding StringFormat="Make a parameter optional in '{0}'">
            <Binding Path="MethodName"/>
          </MultiBinding>
        </TextBlock.Text>
      </TextBlock>
      <TextBlock Foreground="#569CD6" FontSize="11" Margin="0,4,0,0"
                 IsVisible="{Binding ContainingType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock.Text>
          <MultiBinding StringFormat="In: {0}">
            <Binding Path="ContainingType"/>
          </MultiBinding>
        </TextBlock.Text>
      </TextBlock>
    </StackPanel>

    <!-- Current Signature -->
    <TextBlock DockPanel.Dock="Top"
               Text="Current signature:"
               Foreground="{DynamicResource IdeFgMuted}"
               FontSize="11"
               Margin="0,0,0,4"/>
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource IdePanelBg}"
            BorderBrush="{DynamicResource IdeBorder}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8"
            Margin="0,0,0,12">
      <TextBlock Text="{Binding CurrentSignature}"
                 FontFamily="Consolas"
                 FontSize="12"
                 Foreground="#DCDCAA"
                 TextWrapping="Wrap"/>
    </Border>

    <!-- Parameter Selection -->
    <TextBlock DockPanel.Dock="Top"
               Text="Select parameter to make optional:"
               Foreground="{DynamicResource IdeFgMuted}"
               FontSize="11"
               Margin="0,0,0,8"/>

    <Border DockPanel.Dock="Top"
            Background="{DynamicResource IdePanelBg}"
            BorderBrush="{DynamicResource IdeBorder}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,0,0,12"
            Height="100">
      <ListBox ItemsSource="{Binding Parameters}"
               SelectedItem="{Binding SelectedParameter}"
               Background="Transparent"
               Margin="4">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:MakeOptionalParameterViewModel">
            <TextBlock Text="{Binding DisplayText}"
                       FontFamily="Consolas"
                       FontSize="12"
                       Foreground="#9CDCFE"
                       Margin="4,2"/>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <!-- Default Value Input -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
      <TextBlock Grid.Column="0"
                 Text="Default value:"
                 Foreground="{DynamicResource IdeFg}"
                 VerticalAlignment="Center"
                 Margin="0,0,12,0"/>
      <AutoCompleteBox Grid.Column="1"
                       ItemsSource="{Binding CommonDefaultValues}"
                       Text="{Binding DefaultValue}"
                       FilterMode="Contains"
                       Watermark="Enter default value"/>
    </Grid>

    <!-- Options -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <CheckBox IsChecked="{Binding RemoveDefaultArgumentsFromCallSites}">
        <TextBlock Foreground="{DynamicResource IdeFg}">
          <TextBlock.Text>
            <MultiBinding StringFormat="Remove default arguments from call sites ({0} calls)">
              <Binding Path="CallSiteCount"/>
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>
      </CheckBox>
    </StackPanel>

    <!-- Error Message -->
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding ErrorMessage}"
               Foreground="{DynamicResource IdeErrorFg}"
               FontSize="11"
               Margin="0,0,0,8"
               TextWrapping="Wrap"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

    <!-- Preview -->
    <TextBlock DockPanel.Dock="Top"
               Text="Preview:"
               Foreground="{DynamicResource IdeFgMuted}"
               FontSize="11"
               Margin="0,0,0,4"/>
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource IdePanelBg}"
            BorderBrush="{DynamicResource IdeBorder}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,0,0,16"
            MaxHeight="80">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <TextBlock Text="{Binding Preview}"
                   FontFamily="Consolas, Courier New, monospace"
                   FontSize="12"
                   Foreground="#DCDCAA"
                   Padding="8"
                   TextWrapping="NoWrap"/>
      </ScrollViewer>
    </Border>

    <!-- Loading Indicator -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                IsVisible="{Binding IsLoading}"
                Margin="0,0,0,16">
      <TextBlock Text="Processing..." Foreground="{DynamicResource IdeFgMuted}"/>
    </StackPanel>

    <!-- Buttons -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="Cancel"
              Classes="secondary"
              Command="{Binding CancelCommand}"
              Width="80"/>
      <Button Content="Make Optional"
              Command="{Binding MakeOptionalCommand}"
              Width="120"
              Classes="accent"
              IsEnabled="{Binding CanMakeOptional}"/>
    </StackPanel>
  </DockPanel>
</Window>
