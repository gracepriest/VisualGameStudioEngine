<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Dialogs"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="VisualGameStudio.Shell.Views.Dialogs.CommandPaletteDialog"
        x:DataType="vm:CommandPaletteViewModel"
        Title="Command Palette"
        Width="600" Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="BorderOnly"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent">

  <Border Background="{DynamicResource IdeOverlayBg}" CornerRadius="8" BorderBrush="{DynamicResource IdeBorder}" BorderThickness="1">
    <DockPanel>
      <!-- Search Box -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource IdeMenuBg}" Padding="12" CornerRadius="8,8,0,0">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding ModePrefix}"
                     FontSize="16"
                     Foreground="#569CD6"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     FontWeight="Bold"
                     IsVisible="{Binding ModePrefix, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <TextBox Grid.Column="1"
                   x:Name="SearchBox"
                   Text="{Binding SearchText, Mode=TwoWay}"
                   Watermark="{Binding WatermarkText}"
                   FontSize="16"
                   BorderThickness="0"
                   Background="Transparent"
                   Foreground="{DynamicResource IdeFg}"/>
          <Button Grid.Column="2"
                  Command="{Binding DismissCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="6,2"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource IdeFgMuted}"
                  ToolTip.Tip="Close (Esc)"
                  AutomationProperties.Name="Close Command Palette">
            <Button.Styles>
              <Style Selector="Button:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource IdeHeaderBg}"/>
              </Style>
            </Button.Styles>
            <TextBlock Text="✕" FontSize="14"/>
          </Button>
        </Grid>
      </Border>

      <!-- Hint bar. #569CD6 (accent text) kept literal (editor blue, != IdeAccent Dark #3794FF);
           #505050 kept literal (extra-subtle hint text, no theme key has this Dark value). -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource IdeContextBg}" Padding="12,4">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <TextBlock FontSize="11" Foreground="#569CD6"
                     Text="{Binding ModeName}"/>
          <TextBlock Text="Up/Down Navigate" FontSize="11" Foreground="{DynamicResource IdeFgSubtle}"/>
          <TextBlock Text="Enter Execute" FontSize="11" Foreground="{DynamicResource IdeFgSubtle}"/>
          <TextBlock Text="Esc Close" FontSize="11" Foreground="{DynamicResource IdeFgSubtle}"/>
          <TextBlock Text="> Commands  : Line  @ Symbol  # Workspace  ? Help" FontSize="11" Foreground="#505050"/>
        </StackPanel>
      </Border>

      <!-- Section header (recently used / recently opened). #569CD6 kept literal (accent). -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource IdeContextBg}" Padding="12,2"
              IsVisible="{Binding SectionHeader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding SectionHeader}" FontSize="11" Foreground="#569CD6"
                   FontWeight="SemiBold"/>
      </Border>

      <!-- Command List -->
      <ListBox ItemsSource="{Binding FilteredCommands}"
               SelectedItem="{Binding SelectedItem}"
               SelectedIndex="{Binding SelectedIndex}"
               Background="Transparent"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="8,6" Background="Transparent">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- File icon label (only for file items). #333333 chip bg kept literal:
                     no theme key has this Dark value except IdeActivityBarBg (dark-by-design). -->
                <Border Grid.Column="0"
                        IsVisible="{Binding FileIcon, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#333333"
                        CornerRadius="3"
                        Padding="4,2"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                  <TextBlock Text="{Binding FileIcon}"
                             FontSize="10"
                             Foreground="{DynamicResource IdeFgMuted}"
                             FontFamily="Consolas, Courier New, monospace"/>
                </Border>

                <!-- Category + Name. #569CD6 (category accent) kept literal. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding Category}"
                             FontSize="12"
                             Foreground="#569CD6"
                             VerticalAlignment="Center"
                             MinWidth="60"/>
                  <TextBlock Text="{Binding Name}"
                             FontSize="14"
                             Foreground="{DynamicResource IdeFg}"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Keyboard shortcut. #333333 chip bg kept literal (see file-icon note). -->
                <Border Grid.Column="2"
                        IsVisible="{Binding Shortcut, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#333333"
                        CornerRadius="3"
                        Padding="6,2"
                        VerticalAlignment="Center">
                  <TextBlock Text="{Binding Shortcut}"
                             FontSize="11"
                             Foreground="{DynamicResource IdeFgMuted}"
                             FontFamily="Consolas, Courier New, monospace"/>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.Styles>
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource IdeListSelected}"/>
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource IdeListHover}"/>
          </Style>
        </ListBox.Styles>
      </ListBox>
    </DockPanel>
  </Border>
</Window>
