<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Panels"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="600"
             x:Class="VisualGameStudio.Shell.Views.Panels.FindInFilesView"
             x:DataType="vm:FindInFilesViewModel">

  <Border Classes="toolPanel">
    <DockPanel>
      <!-- Panel Header -->
      <Border DockPanel.Dock="Top" Classes="panelHeader">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
          <!-- Toggle replace mode chevron -->
          <Button Grid.Column="0"
                  Classes="toolbarButton"
                  Command="{Binding ToggleReplaceModeCommand}"
                  Width="20" Height="20"
                  Padding="0" Margin="4,0,2,0"
                  ToolTip.Tip="Toggle Replace"
                  AutomationProperties.Name="Toggle Replace Mode">
            <Panel>
              <TextBlock Text=">" FontSize="10" FontFamily="Consolas"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding !IsReplaceMode}"/>
              <TextBlock Text="v" FontSize="10" FontFamily="Consolas"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding IsReplaceMode}"/>
            </Panel>
          </Button>
          <TextBlock Grid.Column="1" Classes="panelTitle" Text="SEARCH" VerticalAlignment="Center"/>
          <!-- Collapse/Expand All -->
          <Button Grid.Column="2" Classes="toolbarButton" Command="{Binding CollapseAllCommand}"
                  Width="22" Height="22" Padding="0" ToolTip.Tip="Collapse All"
                  AutomationProperties.Name="Collapse All Results">
            <TextBlock Text="⊟" FontSize="12" HorizontalAlignment="Center"/>
          </Button>
          <Button Grid.Column="3" Classes="toolbarButton" Command="{Binding ExpandAllCommand}"
                  Width="22" Height="22" Padding="0" ToolTip.Tip="Expand All"
                  AutomationProperties.Name="Expand All Results">
            <TextBlock Text="⊞" FontSize="12" HorizontalAlignment="Center"/>
          </Button>
          <Button Grid.Column="4" Classes="toolbarButton" Command="{Binding ClearResultsCommand}"
                  Width="22" Height="22" Padding="0" Margin="0,0,4,0" ToolTip.Tip="Clear Search Results"
                  AutomationProperties.Name="Clear Results">
            <TextBlock Text="✕" FontSize="10" HorizontalAlignment="Center"/>
          </Button>
        </Grid>
      </Border>

      <!-- Search Controls Area -->
      <Border DockPanel.Dock="Top" Background="#252526" Padding="8,6">
        <StackPanel Spacing="4">
          <!-- Search Input Row -->
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" RowDefinitions="Auto">
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="0"
                     Text="{Binding SearchText}"
                     Watermark="Search"
                     MinHeight="26" FontSize="12"
                     Padding="6,4"
                     KeyDown="OnSearchKeyDown"
                     AutomationProperties.Name="Search Query"/>
            <!-- Regex toggle -->
            <ToggleButton Grid.Column="1" IsChecked="{Binding IsRegex}"
                          Width="26" Height="26" Margin="2,0,0,0" Padding="0"
                          ToolTip.Tip="Use Regular Expression"
                          AutomationProperties.Name="Toggle Regex"
                          Classes="searchToggle">
              <TextBlock Text=".*" FontSize="11" FontFamily="Consolas"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>
            <!-- Case toggle -->
            <ToggleButton Grid.Column="2" IsChecked="{Binding MatchCase}"
                          Width="26" Height="26" Margin="2,0,0,0" Padding="0"
                          ToolTip.Tip="Match Case"
                          AutomationProperties.Name="Toggle Case Sensitivity"
                          Classes="searchToggle">
              <TextBlock Text="Aa" FontSize="11" FontWeight="Bold"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>
            <!-- Whole word toggle -->
            <ToggleButton Grid.Column="3" IsChecked="{Binding MatchWholeWord}"
                          Width="26" Height="26" Margin="2,0,0,0" Padding="0"
                          ToolTip.Tip="Match Whole Word"
                          AutomationProperties.Name="Toggle Whole Word"
                          Classes="searchToggle">
              <TextBlock Text="ab" FontSize="11" TextDecorations="Underline"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>
            <!-- Search button -->
            <Button Grid.Column="4" Classes="toolbarButton"
                    Command="{Binding SearchCommand}"
                    IsEnabled="{Binding !IsSearching}"
                    Width="26" Height="26" Margin="4,0,0,0" Padding="0"
                    ToolTip.Tip="Search (Enter)"
                    AutomationProperties.Name="Execute Search">
              <TextBlock Text="&#x1F50D;" FontSize="12"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
          </Grid>

          <!-- Replace Input Row (visible when replace mode is on) -->
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto"
                IsVisible="{Binding IsReplaceMode}">
            <TextBox x:Name="ReplaceTextBox"
                     Grid.Column="0"
                     Text="{Binding ReplaceText}"
                     Watermark="Replace"
                     MinHeight="26" FontSize="12"
                     Padding="6,4"
                     KeyDown="OnReplaceKeyDown"
                     AutomationProperties.Name="Replace Text"/>
            <!-- Preserve case toggle -->
            <ToggleButton Grid.Column="1" IsChecked="{Binding PreserveCase}"
                          Width="26" Height="26" Margin="2,0,0,0" Padding="0"
                          ToolTip.Tip="Preserve Case"
                          AutomationProperties.Name="Toggle Preserve Case"
                          Classes="searchToggle">
              <TextBlock Text="AB" FontSize="10" FontStyle="Italic"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>
            <!-- Replace All button -->
            <Button Grid.Column="2" Classes="toolbarButton"
                    Command="{Binding ReplaceAllCommand}"
                    IsEnabled="{Binding !IsSearching}"
                    Width="26" Height="26" Margin="2,0,0,0" Padding="0"
                    ToolTip.Tip="Replace All"
                    AutomationProperties.Name="Replace All Matches">
              <TextBlock Text="&#x21C4;" FontSize="14"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
          </Grid>

          <!-- Include/Exclude Filters (collapsible) -->
          <StackPanel Spacing="4">
            <Button Classes="toolbarButton" Command="{Binding ToggleFiltersCommand}"
                    HorizontalAlignment="Left" Padding="2,0" Height="18"
                    AutomationProperties.Name="Toggle File Filters">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Panel>
                  <TextBlock Text="..." FontSize="10" FontFamily="Consolas" IsVisible="{Binding !ShowFilters}"/>
                  <TextBlock Text="v" FontSize="10" FontFamily="Consolas" IsVisible="{Binding ShowFilters}"/>
                </Panel>
                <TextBlock Text="files to include/exclude" FontSize="11" Foreground="#808080"/>
              </StackPanel>
            </Button>

            <StackPanel Spacing="4" IsVisible="{Binding ShowFilters}">
              <TextBox Text="{Binding IncludePattern}"
                       Watermark="files to include (e.g., *.bas, *.cs)"
                       MinHeight="24" FontSize="11" Padding="6,3"
                       AutomationProperties.Name="Include File Pattern"/>
              <TextBox Text="{Binding ExcludePattern}"
                       Watermark="files to exclude (e.g., **/bin/**, *.dll)"
                       MinHeight="24" FontSize="11" Padding="6,3"
                       AutomationProperties.Name="Exclude File Pattern"/>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Status / Summary Bar -->
      <Border DockPanel.Dock="Bottom" Background="#1E1E1E" Padding="8,3" MinHeight="22">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding StatusText}"
                     Foreground="#808080" FontSize="11"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     AutomationProperties.Name="Search Status"/>
          <Button Grid.Column="1" Classes="toolbarButton"
                  Command="{Binding CancelSearchCommand}"
                  IsVisible="{Binding IsSearching}"
                  Width="50" Height="20" Padding="0"
                  AutomationProperties.Name="Cancel Search">
            <TextBlock Text="Cancel" FontSize="11"/>
          </Button>
        </Grid>
      </Border>

      <!-- Results Area -->
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <Panel>
          <!-- Empty state (no results) -->
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                      Margin="16" Spacing="8"
                      IsVisible="{Binding HasNoResults}">
            <TextBlock Text="Search" FontSize="14" Foreground="#606060"
                       HorizontalAlignment="Center" IsVisible="{Binding !IsSearching}"/>
            <TextBlock Text="Type in the search box and press Enter" FontSize="11" Foreground="#505050"
                       HorizontalAlignment="Center" IsVisible="{Binding !IsSearching}" TextWrapping="Wrap"
                       TextAlignment="Center"/>
            <TextBlock FontSize="11" Foreground="#505050" HorizontalAlignment="Center"
                       IsVisible="{Binding !IsSearching}" TextWrapping="Wrap" TextAlignment="Center">
              <Run Text="Tip: Use "/>
              <Run Text=".*" FontFamily="Consolas" Foreground="#569CD6"/>
              <Run Text=" for regex, "/>
              <Run Text="Aa" FontWeight="Bold" Foreground="#569CD6"/>
              <Run Text=" for case sensitive"/>
            </TextBlock>
          </StackPanel>

          <!-- Results tree -->
          <ItemsControl ItemsSource="{Binding Results}"
                        IsVisible="{Binding HasResults}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:SearchResultFileViewModel">
                <StackPanel>
                  <!-- File Header Row -->
                  <Border Background="Transparent" Cursor="Hand" Padding="4,3"
                          PointerPressed="OnFileHeaderPressed">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                      <!-- Expand/Collapse chevron -->
                      <Panel Grid.Column="0" Width="14" Margin="2,0,2,0">
                        <TextBlock Text="&#x25B6;" FontSize="9" VerticalAlignment="Center"
                                   Foreground="#808080" IsVisible="{Binding !IsExpanded}"/>
                        <TextBlock Text="&#x25BC;" FontSize="9" VerticalAlignment="Center"
                                   Foreground="#808080" IsVisible="{Binding IsExpanded}"/>
                      </Panel>
                      <!-- File icon -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding FileIcon}"
                                 FontSize="11" Width="16" VerticalAlignment="Center"
                                 Foreground="#808080" Margin="0,0,4,0"/>
                      <!-- File name and path -->
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FileName}" Foreground="#DCDCAA" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RelativePath}" Foreground="#606060" FontSize="11"
                                   TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                      </StackPanel>
                      <!-- Match count badge -->
                      <Border Grid.Column="3" Background="#3C3C3C" CornerRadius="8"
                              Padding="6,1" Margin="4,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MatchCount}" FontSize="10" Foreground="#CCCCCC"
                                   HorizontalAlignment="Center"/>
                      </Border>
                      <!-- Dismiss button -->
                      <Button Grid.Column="4" Classes="toolbarButton" Width="18" Height="18"
                              Padding="0" Margin="0,0,2,0"
                              Command="{Binding $parent[ItemsControl].((vm:FindInFilesViewModel)DataContext).DismissFileResultCommand}"
                              CommandParameter="{Binding}"
                              ToolTip.Tip="Dismiss"
                              AutomationProperties.Name="Dismiss File Result">
                        <TextBlock Text="x" FontSize="10" Foreground="#808080"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Button>
                    </Grid>
                  </Border>

                  <!-- Replace in file button (visible in replace mode) -->
                  <Border IsVisible="{Binding $parent[ItemsControl].((vm:FindInFilesViewModel)DataContext).IsReplaceMode}"
                          Padding="20,0,4,2">
                    <Button Classes="toolbarButton" Height="18" Padding="6,0"
                            Command="{Binding $parent[ItemsControl].((vm:FindInFilesViewModel)DataContext).ReplaceInFileCommand}"
                            CommandParameter="{Binding}"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="Replace All in This File">
                      <TextBlock Text="Replace" FontSize="10" Foreground="#808080"/>
                    </Button>
                  </Border>

                  <!-- Matches (shown when expanded) -->
                  <ItemsControl ItemsSource="{Binding Matches}" IsVisible="{Binding IsExpanded}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:SearchResultMatchViewModel">
                        <Border Background="Transparent" Cursor="Hand" Padding="20,2,4,2"
                                Tapped="OnMatchPressed">
                          <Border.Styles>
                            <Style Selector="Border:pointerover">
                              <Setter Property="Background" Value="#2A2D2E"/>
                            </Style>
                          </Border.Styles>
                          <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Line number -->
                            <TextBlock Grid.Column="0" Text="{Binding LineNumberText}"
                                       FontSize="11" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="#858585" MinWidth="30" TextAlignment="Right"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <!-- Line preview with highlighted match -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" ClipToBounds="True"
                                        VerticalAlignment="Center">
                              <TextBlock Text="{Binding PreviewBefore}" Foreground="#D4D4D4"
                                         FontSize="11" FontFamily="Cascadia Code, Consolas, monospace"/>
                              <Border Background="#E2C08D" CornerRadius="2" Padding="0">
                                <TextBlock Text="{Binding MatchText}" Foreground="#000000"
                                           FontSize="11" FontFamily="Cascadia Code, Consolas, monospace"/>
                              </Border>
                              <TextBlock Text="{Binding PreviewAfter}" Foreground="#D4D4D4"
                                         FontSize="11" FontFamily="Cascadia Code, Consolas, monospace"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <!-- Dismiss match button -->
                            <Button Grid.Column="2" Classes="toolbarButton dismissMatch" Width="16" Height="16"
                                    Padding="0" Margin="2,0,0,0" Opacity="0"
                                    Command="{Binding $parent[ItemsControl;1].((vm:FindInFilesViewModel)DataContext).DismissMatchResultCommand}"
                                    CommandParameter="{Binding}"
                                    AutomationProperties.Name="Dismiss Match">
                              <TextBlock Text="x" FontSize="9" Foreground="#808080"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Panel>
      </ScrollViewer>
    </DockPanel>
  </Border>

  <UserControl.Styles>
    <!-- Search toggle button styling -->
    <Style Selector="ToggleButton.searchToggle">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Foreground" Value="#808080"/>
    </Style>
    <Style Selector="ToggleButton.searchToggle:checked">
      <Setter Property="Background" Value="#3C3C3C"/>
      <Setter Property="BorderBrush" Value="#569CD6"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>
    <Style Selector="ToggleButton.searchToggle:pointerover">
      <Setter Property="Background" Value="#3C3C3C"/>
    </Style>
    <!-- Show dismiss button on match row hover -->
    <Style Selector="Border:pointerover > Grid > Button.dismissMatch">
      <Setter Property="Opacity" Value="1"/>
    </Style>
  </UserControl.Styles>
</UserControl>
