<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Panels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="200"
             x:Class="VisualGameStudio.Shell.Views.Panels.OutputPanelView"
             x:DataType="vm:OutputPanelViewModel">

  <UserControl.Styles>
    <!-- Compact rows: keep the old dense terminal look instead of the tall default ListBoxItem -->
    <Style Selector="ListBox#OutputListBox ListBoxItem">
      <Setter Property="Padding" Value="2,1"/>
      <Setter Property="MinHeight" Value="0"/>
    </Style>
    <!-- Default line color, set at style level so the error/warning class styles can override it -->
    <Style Selector="ListBox#OutputListBox TextBlock">
      <Setter Property="Foreground" Value="#CCCCCC"/>
    </Style>
    <!-- Clickable output lines: underlined, hand cursor on hover (double-click navigates) -->
    <Style Selector="ListBox#OutputListBox TextBlock.clickable">
      <Setter Property="TextDecorations" Value="Underline"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="ListBox#OutputListBox TextBlock.clickable:pointerover">
      <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <!-- Error lines: red -->
    <Style Selector="ListBox#OutputListBox TextBlock.error">
      <Setter Property="Foreground" Value="#F14C4C"/>
    </Style>
    <!-- Warning lines: yellow -->
    <Style Selector="ListBox#OutputListBox TextBlock.warning">
      <Setter Property="Foreground" Value="#CCA700"/>
    </Style>
  </UserControl.Styles>

  <Border Classes="toolPanel">
    <DockPanel>
      <Border DockPanel.Dock="Top" Classes="panelHeader">
        <DockPanel>
          <TextBlock Text="Output" Classes="panelTitle" DockPanel.Dock="Left"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
            <Button Content="Build" Command="{Binding ShowBuildOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show Build Output"/>
            <Button Content="Debug" Command="{Binding ShowDebugOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show Debug Output"/>
            <Button Content="LSP" Command="{Binding ShowLspOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show LSP Output"/>
            <Button Content="General" Command="{Binding ShowGeneralOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show General Output"/>
            <Button Content="Clear" Command="{Binding ClearCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Clear Output"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Input area at the bottom -->
      <Border DockPanel.Dock="Bottom"
              Background="#252526"
              Padding="4"
              IsVisible="{Binding IsInputEnabled}">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Content="Send"
                  Command="{Binding SendInputCommand}"
                  Padding="12,4"
                  Margin="4,0,0,0"
                  AutomationProperties.Name="Send Output Panel Input"/>
          <TextBox Text="{Binding InputText}"
                   Watermark="Type input and press Enter..."
                   FontFamily="Cascadia Code, Consolas, monospace"
                   FontSize="12"
                   Background="#1E1E1E"
                   Foreground="#CCCCCC"
                   x:Name="InputTextBox"
                   AutomationProperties.Name="Output Panel Input"/>
        </DockPanel>
      </Border>

      <!-- Output lines: multi-selectable and copyable (Ctrl+C / Ctrl+A / right-click menu).
           Double-click an error/warning line to navigate to the source location.
           The ListBox provides its own (virtualizing) scrolling. -->
      <ListBox x:Name="OutputListBox"
               ItemsSource="{Binding OutputLines}"
               SelectionMode="Multiple"
               Focusable="True"
               Background="#1E1E1E"
               BorderThickness="0"
               Padding="4,2"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               KeyDown="OnOutputListKeyDown"
               PointerPressed="OnOutputListPointerPressed"
               DoubleTapped="OnOutputListDoubleTapped"
               AutomationProperties.Name="Output Lines">
        <ListBox.ContextMenu>
          <ContextMenu Opening="OnOutputContextMenuOpening">
            <MenuItem Name="OutputCopyMenuItem" Header="Copy" InputGesture="Ctrl+C"
                      Click="OnCopySelectedClick"/>
            <MenuItem Name="OutputCopyAllMenuItem" Header="Copy All"
                      Click="OnCopyAllClick"/>
            <Separator/>
            <MenuItem Name="OutputClearMenuItem" Header="Clear"
                      Command="{Binding ClearCommand}"/>
          </ContextMenu>
        </ListBox.ContextMenu>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:OutputLine">
            <TextBlock Text="{Binding Text}"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="12"
                       TextWrapping="NoWrap"
                       Classes.clickable="{Binding IsClickable}"
                       Classes.error="{Binding IsError}"
                       Classes.warning="{Binding IsWarning}"/>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>
  </Border>

</UserControl>
