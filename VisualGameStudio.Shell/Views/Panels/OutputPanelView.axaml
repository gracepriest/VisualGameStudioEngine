<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Panels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="200"
             x:Class="VisualGameStudio.Shell.Views.Panels.OutputPanelView"
             x:DataType="vm:OutputPanelViewModel">

  <UserControl.Styles>
    <!-- Clickable output lines: underlined, hand cursor on hover -->
    <Style Selector="ItemsControl TextBlock.clickable">
      <Setter Property="TextDecorations" Value="Underline"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="ItemsControl TextBlock.clickable:pointerover">
      <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <!-- Error lines: red -->
    <Style Selector="ItemsControl TextBlock.error">
      <Setter Property="Foreground" Value="#F14C4C"/>
    </Style>
    <!-- Warning lines: yellow -->
    <Style Selector="ItemsControl TextBlock.warning">
      <Setter Property="Foreground" Value="#CCA700"/>
    </Style>
  </UserControl.Styles>

  <Border Classes="toolPanel">
    <DockPanel>
      <Border DockPanel.Dock="Top" Classes="panelHeader">
        <DockPanel>
          <TextBlock Text="Output" Classes="panelTitle" DockPanel.Dock="Left"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
            <Button Content="Build" Command="{Binding ShowBuildOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show Build Output"/>
            <Button Content="Debug" Command="{Binding ShowDebugOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show Debug Output"/>
            <Button Content="LSP" Command="{Binding ShowLspOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show LSP Output"/>
            <Button Content="General" Command="{Binding ShowGeneralOutputCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Show General Output"/>
            <Button Content="Clear" Command="{Binding ClearCommand}"
                    Padding="8,2" FontSize="11"
                    AutomationProperties.Name="Clear Output"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Input area at the bottom -->
      <Border DockPanel.Dock="Bottom"
              Background="#252526"
              Padding="4"
              IsVisible="{Binding IsInputEnabled}">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Content="Send"
                  Command="{Binding SendInputCommand}"
                  Padding="12,4"
                  Margin="4,0,0,0"
                  AutomationProperties.Name="Send Output Panel Input"/>
          <TextBox Text="{Binding InputText}"
                   Watermark="Type input and press Enter..."
                   FontFamily="Cascadia Code, Consolas, monospace"
                   FontSize="12"
                   Background="#1E1E1E"
                   Foreground="#CCCCCC"
                   x:Name="InputTextBox"
                   AutomationProperties.Name="Output Panel Input"/>
        </DockPanel>
      </Border>

      <!-- Output lines with clickable error/warning entries -->
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Background="#1E1E1E"
                    x:Name="OutputScroller">
        <ItemsControl ItemsSource="{Binding OutputLines}"
                      Padding="4,2"
                      AutomationProperties.Name="Output Lines">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:OutputLine">
              <TextBlock Text="{Binding Text}"
                         FontFamily="Cascadia Code, Consolas, monospace"
                         FontSize="12"
                         Foreground="#CCCCCC"
                         TextWrapping="NoWrap"
                         Padding="2,1"
                         Classes.clickable="{Binding IsClickable}"
                         Classes.error="{Binding IsError}"
                         Classes.warning="{Binding IsWarning}"
                         PointerPressed="OnOutputLinePointerPressed"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </DockPanel>
  </Border>

</UserControl>
