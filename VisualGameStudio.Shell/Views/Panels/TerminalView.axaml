<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Panels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="300"
             x:Class="VisualGameStudio.Shell.Views.Panels.TerminalView"
             x:DataType="vm:TerminalViewModel">

  <Border Classes="toolPanel">
    <DockPanel>
      <!-- Header with tab bar and toolbar -->
      <Border DockPanel.Dock="Top" Classes="panelHeader">
        <DockPanel>
          <!-- Right-side toolbar buttons -->
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
            <Button Classes="toolbarButton"
                    Command="{Binding StartCommand}"
                    ToolTip.Tip="Start Terminal"
                    IsVisible="{Binding !IsRunning}"
                    AutomationProperties.Name="Start Terminal">
              <TextBlock Text="&#x25B6;" FontSize="12" Foreground="#89D185"/>
            </Button>

            <Button Classes="toolbarButton"
                    Command="{Binding StopCommand}"
                    ToolTip.Tip="Stop Terminal"
                    IsVisible="{Binding IsRunning}"
                    AutomationProperties.Name="Stop Terminal">
              <TextBlock Text="&#x25A0;" FontSize="12" Foreground="#E51400"/>
            </Button>

            <Button Classes="toolbarButton"
                    Command="{Binding ClearCommand}"
                    ToolTip.Tip="Clear"
                    AutomationProperties.Name="Clear Terminal Output">
              <TextBlock Text="Clear" FontSize="11"/>
            </Button>

            <Button Classes="toolbarButton"
                    Command="{Binding SplitTerminalCommand}"
                    ToolTip.Tip="Split Terminal (Ctrl+Shift+5)"
                    Margin="4,0,0,0"
                    AutomationProperties.Name="Split Terminal (Ctrl+Shift+5)">
              <TextBlock Text="&#x2551;" FontSize="14" Foreground="#569CD6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
          </StackPanel>

          <!-- Tab bar (scrollable) -->
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled"
                        Margin="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <!-- Terminal session tabs -->
              <ItemsControl ItemsSource="{Binding Sessions}" x:Name="TabsItemsControl">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="1"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:TerminalSession" x:CompileBindings="False">
                    <Border x:Name="TabBorder"
                            Background="#2D2D2D"
                            CornerRadius="4,4,0,0"
                            Padding="6,3"
                            Margin="1,2,0,0"
                            Cursor="Hand"
                            PointerPressed="OnTabPointerPressed">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <!-- Shell icon -->
                        <TextBlock Text="&#x25BA;"
                                   FontSize="9"
                                   Foreground="#569CD6"
                                   VerticalAlignment="Center"/>
                        <!-- Tab title -->
                        <TextBlock Text="{Binding TabTitle}"
                                   FontSize="11"
                                   Foreground="#CCCCCC"
                                   VerticalAlignment="Center"/>
                        <!-- Close button -->
                        <Button Classes="toolbarButton"
                                Click="OnCloseTabClick"
                                ToolTip.Tip="Close Terminal"
                                Padding="2"
                                MinWidth="16" MinHeight="16"
                                Width="16" Height="16"
                                VerticalAlignment="Center">
                          <TextBlock Text="&#x00D7;" FontSize="12" Foreground="#808080"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- New terminal button + shell profile selector -->
              <StackPanel Orientation="Horizontal" Margin="4,2,0,0" Spacing="0">
                <!-- "+" button: creates new terminal with current default profile -->
                <Button Classes="toolbarButton"
                        Command="{Binding CreateNewSessionCommand}"
                        ToolTip.Tip="New Terminal (Ctrl+Shift+`)"
                        Padding="4,3"
                        MinWidth="24" MinHeight="20"
                        AutomationProperties.Name="New Terminal (Ctrl+Shift+`)">
                  <TextBlock Text="+" FontSize="14" Foreground="#89D185"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Dropdown chevron to pick a specific shell profile -->
                <Button Classes="toolbarButton"
                        x:Name="ProfileDropdownButton"
                        Click="OnProfileDropdownClick"
                        ToolTip.Tip="Select Shell Profile"
                        Padding="2,3"
                        MinWidth="16" MinHeight="20">
                  <TextBlock Text="&#x25BC;" FontSize="8" Foreground="#89D185"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Shell profile flyout popup -->
                <Popup x:Name="ProfilePopup"
                       PlacementTarget="{Binding #ProfileDropdownButton}"
                       Placement="BottomEdgeAlignedLeft"
                       IsOpen="{Binding IsProfileDropdownOpen, Mode=TwoWay}"
                       IsLightDismissEnabled="True"
                       MaxHeight="300">
                  <Border Background="#252526"
                          BorderBrush="#3C3C3C"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="2"
                          MinWidth="200">
                    <StackPanel>
                      <!-- Header -->
                      <TextBlock Text="Select Default Profile"
                                 FontSize="11"
                                 Foreground="#808080"
                                 Margin="8,4,8,4"/>
                      <Separator Background="#3C3C3C" Height="1" Margin="4,0"/>

                      <!-- Profile list -->
                      <ItemsControl ItemsSource="{Binding AvailableProfiles}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:ShellProfile">
                            <Button Classes="toolbarButton"
                                    Click="OnProfileItemClick"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="8,6"
                                    Margin="2,1"
                                    CornerRadius="3">
                              <StackPanel Orientation="Horizontal" Spacing="8">
                                <!-- Profile icon badge -->
                                <Border Background="#3C3C3C"
                                        CornerRadius="2"
                                        Padding="4,1"
                                        MinWidth="32"
                                        HorizontalAlignment="Center">
                                  <TextBlock Text="{Binding Icon}"
                                             FontSize="9"
                                             Foreground="#569CD6"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>
                                <!-- Profile name -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"/>
                              </StackPanel>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <Separator Background="#3C3C3C" Height="1" Margin="4,2"/>

                      <!-- Current default indicator -->
                      <StackPanel Orientation="Horizontal" Margin="8,4,8,6" Spacing="4">
                        <TextBlock Text="Default:"
                                   FontSize="10"
                                   Foreground="#808080"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedProfile.Name}"
                                   FontSize="10"
                                   Foreground="#569CD6"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Popup>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- Input -->
      <Border DockPanel.Dock="Bottom" Background="#1E1E1E" Padding="4">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Column="0"
                     Text=">"
                     Foreground="#569CD6"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     VerticalAlignment="Center"
                     Margin="4,0,8,0"/>

          <TextBox Grid.Column="1"
                   Text="{Binding InputText}"
                   FontFamily="Cascadia Code, Consolas, monospace"
                   FontSize="13"
                   Background="#1E1E1E"
                   BorderThickness="0"
                   IsEnabled="{Binding IsRunning}"
                   x:Name="InputBox"
                   AutomationProperties.Name="Terminal Input"/>

          <Button Grid.Column="2"
                  Classes="toolbarButton"
                  Command="{Binding SendInputCommand}"
                  IsEnabled="{Binding IsRunning}"
                  Margin="4,0,0,0"
                  AutomationProperties.Name="Send Terminal Input">
            <TextBlock Text="Send" FontSize="11"/>
          </Button>
        </Grid>
      </Border>

      <!-- Output with ANSI color support + search overlay + split pane -->
      <Grid x:Name="OutputGrid">
        <!-- Single-pane and split-pane columns are configured dynamically in code-behind -->
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="0"/>
          <ColumnDefinition Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- Left pane (primary) -->
        <Grid Grid.Column="0">
          <Border x:Name="LeftPaneBorder"
                  BorderThickness="0"
                  BorderBrush="#569CD6"
                  PointerPressed="OnLeftPanePointerPressed">
            <ScrollViewer Background="#0C0C0C"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          x:Name="OutputScroller">
              <SelectableTextBlock FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="13"
                                   Foreground="#CCCCCC"
                                   Padding="8"
                                   TextWrapping="NoWrap"
                                   x:Name="OutputTextBlock"
                                   AutomationProperties.Name="Terminal Output"/>
            </ScrollViewer>
          </Border>

          <!-- Search bar (Ctrl+F) -->
          <Border x:Name="SearchBar"
                  IsVisible="False"
                  Background="#252526"
                  BorderBrush="#3C3C3C"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="6,4"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="8,8,24,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBox x:Name="SearchTextBox"
                       Width="220"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="12"
                       Background="#3C3C3C"
                       Foreground="#CCCCCC"
                       BorderThickness="1"
                       BorderBrush="#555555"
                       Watermark="Find in terminal..."
                       Padding="4,3"
                       AutomationProperties.Name="Find in Terminal"/>
              <TextBlock x:Name="SearchMatchCount"
                         Text="No results"
                         Foreground="#808080"
                         FontSize="11"
                         VerticalAlignment="Center"
                         MinWidth="70"/>
              <Button Classes="toolbarButton"
                      x:Name="SearchPrevButton"
                      Click="OnSearchPrevClick"
                      ToolTip.Tip="Previous Match (Shift+Enter)"
                      Padding="4,2"
                      MinWidth="24" MinHeight="22">
                <TextBlock Text="&#x25B2;" FontSize="10" Foreground="#CCCCCC"/>
              </Button>
              <Button Classes="toolbarButton"
                      x:Name="SearchNextButton"
                      Click="OnSearchNextClick"
                      ToolTip.Tip="Next Match (Enter)"
                      Padding="4,2"
                      MinWidth="24" MinHeight="22">
                <TextBlock Text="&#x25BC;" FontSize="10" Foreground="#CCCCCC"/>
              </Button>
              <Button Classes="toolbarButton"
                      x:Name="SearchCloseButton"
                      Click="OnSearchCloseClick"
                      ToolTip.Tip="Close (Escape)"
                      Padding="4,2"
                      MinWidth="24" MinHeight="22">
                <TextBlock Text="&#x00D7;" FontSize="14" Foreground="#808080"/>
              </Button>
            </StackPanel>
          </Border>
        </Grid>

        <!-- GridSplitter (visible only when split) -->
        <GridSplitter Grid.Column="1"
                      x:Name="PaneSplitter"
                      Width="4"
                      Background="#3C3C3C"
                      IsVisible="False"
                      ResizeDirection="Columns"/>

        <!-- Right pane (split) -->
        <Grid Grid.Column="2" x:Name="RightPaneGrid" IsVisible="False">
          <Border x:Name="RightPaneBorder"
                  BorderThickness="0"
                  BorderBrush="#569CD6"
                  PointerPressed="OnRightPanePointerPressed">
            <ScrollViewer Background="#0C0C0C"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          x:Name="SplitOutputScroller">
              <SelectableTextBlock FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="13"
                                   Foreground="#CCCCCC"
                                   Padding="8"
                                   TextWrapping="NoWrap"
                                   x:Name="SplitOutputTextBlock"/>
            </ScrollViewer>
          </Border>

          <!-- Close split pane button -->
          <Button Classes="toolbarButton"
                  Command="{Binding UnsplitTerminalCommand}"
                  ToolTip.Tip="Close Split Pane"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,4,8,0"
                  Padding="4,2"
                  MinWidth="20" MinHeight="20">
            <TextBlock Text="&#x00D7;" FontSize="12" Foreground="#808080"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Button>
        </Grid>
      </Grid>
    </DockPanel>
  </Border>
</UserControl>
