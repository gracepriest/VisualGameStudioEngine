<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VisualGameStudio.Shell.ViewModels.Panels"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="400"
             x:Class="VisualGameStudio.Shell.Views.Panels.SolutionExplorerView"
             x:DataType="vm:SolutionExplorerViewModel">

  <Border Classes="toolPanel">
    <DockPanel>
      <Border DockPanel.Dock="Top" Classes="panelHeader">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="Solution Explorer" Classes="panelTitle"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
            <Button Classes="toolbarButton"
                    ToolTip.Tip="Add New File"
                    Command="{Binding AddNewFileCommand}"
                    Width="24" Height="24"
                    AutomationProperties.Name="Add New File">
              <TextBlock Text="+" FontSize="14" FontWeight="Bold"/>
            </Button>
            <Button Classes="toolbarButton"
                    ToolTip.Tip="Add New Folder"
                    Command="{Binding AddNewFolderCommand}"
                    Width="24" Height="24"
                    AutomationProperties.Name="Add New Folder">
              <TextBlock Text="📁" FontSize="12"/>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <TreeView x:Name="SolutionTreeView"
                ItemsSource="{Binding Nodes}"
                SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                Background="Transparent"
                DoubleTapped="OnTreeViewDoubleTapped"
                AutomationProperties.Name="Solution Explorer Tree">

        <TreeView.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Add">
              <MenuItem Header="New BasicLang File (.bas)" Command="{Binding #SolutionTreeView.DataContext.AddNewBasicLangFileCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="B" FontSize="12" FontWeight="Bold" Foreground="#569CD6"/>
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="New Module (.mod)" Command="{Binding #SolutionTreeView.DataContext.AddNewModuleCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="M" FontSize="12" FontWeight="Bold" Foreground="#4FC3F7"/>
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="New Class (.cls)" Command="{Binding #SolutionTreeView.DataContext.AddNewClassCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="C" FontSize="12" FontWeight="Bold" Foreground="#66BB6A"/>
                </MenuItem.Icon>
              </MenuItem>
              <Separator/>
              <MenuItem Header="New File..." Command="{Binding #SolutionTreeView.DataContext.AddNewFileCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="+" FontSize="12" FontWeight="Bold"/>
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="New Folder..." Command="{Binding #SolutionTreeView.DataContext.AddNewFolderCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="D" FontSize="12" FontWeight="Bold"/>
                </MenuItem.Icon>
              </MenuItem>
              <Separator/>
              <MenuItem Header="Existing File..." Command="{Binding #SolutionTreeView.DataContext.AddExistingFileCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="+" FontSize="12"/>
                </MenuItem.Icon>
              </MenuItem>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Open" Click="OnOpenMenuItemClick"/>
            <Separator/>
            <MenuItem Header="Rename" Command="{Binding #SolutionTreeView.DataContext.StartRenameCommand}" InputGesture="F2"/>
            <MenuItem Header="Delete" Command="{Binding #SolutionTreeView.DataContext.DeleteCommand}" InputGesture="Delete">
              <MenuItem.Icon>
                <TextBlock Text="🗑" FontSize="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Open in Explorer" Command="{Binding #SolutionTreeView.DataContext.OpenInExplorerCommand}"/>
            <MenuItem Header="Open in Terminal" Command="{Binding #SolutionTreeView.DataContext.OpenInTerminalCommand}"/>
            <MenuItem Header="Copy Path" Command="{Binding #SolutionTreeView.DataContext.CopyPathCommand}"/>
          </ContextMenu>
        </TreeView.ContextMenu>

        <TreeView.ItemTemplate>
          <TreeDataTemplate ItemsSource="{Binding Children}">
            <Grid ColumnDefinitions="Auto,*,Auto" DoubleTapped="OnItemDoubleTapped">
              <!-- Icon based on node type, with file-specific icons for .mod (M) and .cls/.class (C) -->
              <TextBlock Grid.Column="0"
                         Text="{Binding ., Converter={x:Static vm:NodeTypeIconConverter.Instance}}"
                         Foreground="{Binding FullPath, Converter={x:Static vm:FileExtensionIconConverter.Instance}}"
                         Margin="0,0,6,0"
                         FontSize="14"
                         FontWeight="Bold"
                         VerticalAlignment="Center"/>

              <!-- Name (always visible - rename handled elsewhere) -->
              <TextBlock Grid.Column="1"
                         Text="{Binding Name}"
                         Foreground="#CCCCCC"
                         VerticalAlignment="Center"/>
            </Grid>
          </TreeDataTemplate>
        </TreeView.ItemTemplate>

        <TreeView.Styles>
          <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
          </Style>
        </TreeView.Styles>
      </TreeView>
    </DockPanel>
  </Border>

</UserControl>
